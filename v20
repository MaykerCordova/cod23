# ==========================
# Conexión a Outlook
# ==========================
def _conectar_outlook_folder(folder_name: str):
    """Retorna la carpeta de Outlook con el nombre indicado."""
    outlook_ns   = win32.Dispatch("Outlook.Application").GetNamespace("MAPI")
    root_folder  = outlook_ns.GetDefaultFolder(6)   # 6 = Inbox
    for folder in root_folder.Folders:
        if folder.Name == folder_name:
            return folder
    raise ValueError(f"No se encontró la carpeta '{folder_name}' en Outlook.")


# ==========================
# Lógica robusta: última fecha registrada en Excel
# ==========================
def _obtener_ultima_fecha_excel() -> date:
    """
    Lee el Excel y retorna la ultima fecha registrada en la columna Fecha.
    Usa dayfirst=True para cubrir formato peruano dd/mm/yyyy.
    Imprime la fecha encontrada para facilitar diagnostico.
    """
    try:
        df = pd.read_excel(RUTA_EXCEL)
        fechas = pd.to_datetime(
            df["Fecha"], errors="coerce", dayfirst=True
        ).dropna()
        if fechas.empty:
            print("[AVISO] No se encontraron fechas en el Excel. Se procesaran todos los correos.")
            return date.min
        ultima = fechas.max().date()
        print(f"[INFO] Ultima fecha registrada en Excel: {ultima.strftime('%d/%m/%Y')}")
        return ultima
    except Exception as e:
        print(f"[AVISO] Error leyendo Excel: {e}. Se procesan todos los correos.")
        return date.min


