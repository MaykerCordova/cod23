def plot_evolucion_mensual(df_full: pd.DataFrame,
                           outfile: str = PNG_MENSUAL,
                           mes_inicio: str = MES_INICIO_MENSUAL) -> str:
    """
    Gráfico mensual con matplotlib:
      - Barras agrupadas UBA/SBP con etiquetas encima (formato miles)
      - Línea de Txns Faltantes en eje Y secundario independiente
      - Puntos coloreados por relación (verde/rojo)
      - Sin eje Y izquierdo visible
      - Estilo limpio corporativo
    """
    import matplotlib.pyplot as plt
    import matplotlib.patches as mpatches
    from matplotlib.lines import Line2D
    import numpy as np

    # ── Datos ───────────────────────────────────────────────────────────────
    df = df_full.copy()
    df["Fecha"] = pd.to_datetime(df["Fecha"], errors="coerce")
    df = df.dropna(subset=["Fecha"])
    df["Mes_Anio"] = df["Fecha"].dt.to_period("M").dt.to_timestamp()
    df = df[df["Mes_Anio"] >= pd.to_datetime(mes_inicio)]

    df_mes = (
        df.sort_values("Fecha")
          .groupby("Mes_Anio", as_index=False)
          .agg({"Txns Faltantes": "sum", "Txns UBA": "sum", "Txns SBP": "sum"})
    )
    df_mes["Relacion"] = np.where(df_mes["Txns Faltantes"] >= 0,
                                  "UBA ≥ SBP", "SBP > UBA")

    n     = len(df_mes)
    x     = np.arange(n)
    w     = 0.38
    meses = df_mes["Mes_Anio"].tolist()
    uba   = df_mes["Txns UBA"].values
    sbp   = df_mes["Txns SBP"].values
    falt  = df_mes["Txns Faltantes"].values
    rels  = df_mes["Relacion"].tolist()

    # ── Figura ──────────────────────────────────────────────────────────────
    fig, ax1 = plt.subplots(figsize=(max(13, n * 1.5), 7), dpi=160)
    fig.patch.set_facecolor("white")
    ax1.set_facecolor("white")
    ax2 = ax1.twinx()

    # Barras
    b1 = ax1.bar(x - w/2, uba, width=w, color=COLOR_UBA,
                 alpha=0.55, label="Txns UBA", zorder=2)
    b2 = ax1.bar(x + w/2, sbp, width=w, color=COLOR_SBP,
                 alpha=0.55, label="Txns SBP", zorder=2)

    # Etiquetas en barras
    ymax_bar = max(uba.max(), sbp.max())
    for bar, val, col in zip(b1, uba, [COLOR_UBA]*n):
        ax1.text(bar.get_x() + bar.get_width()/2,
                 bar.get_height() + ymax_bar * 0.008,
                 f"{val:,.0f}",
                 ha="center", va="bottom",
                 fontsize=7, color="#1a5f8a", fontweight="bold")
    for bar, val in zip(b2, sbp):
        ax1.text(bar.get_x() + bar.get_width()/2,
                 bar.get_height() + ymax_bar * 0.008,
                 f"{val:,.0f}",
                 ha="center", va="bottom",
                 fontsize=7, color="#a04000", fontweight="bold")

    # Eje Y izquierdo: oculto, con margen para etiquetas
    ax1.set_ylim(0, ymax_bar * 1.22)
    ax1.yaxis.set_visible(False)
    ax1.spines["left"].set_visible(False)
    ax1.spines["right"].set_visible(False)
    ax1.spines["top"].set_visible(False)

    # Línea de faltantes en eje derecho
    colores_pts = [COLOR_OK if r == "UBA ≥ SBP" else COLOR_ALERTA for r in rels]
    ax2.plot(x, falt, color="#444444", linewidth=1.8, zorder=3, alpha=0.9)
    ax2.scatter(x, falt, c=colores_pts, s=65, zorder=5)

    # Etiquetas faltantes con caja blanca
    falt_rng = max(abs(falt.max()), abs(falt.min())) if len(falt) else 1
    for xi, yi, val in zip(x, falt, falt):
        ax2.annotate(
            f"{int(val):,}",
            xy=(xi, yi),
            xytext=(0, 11), textcoords="offset points",
            ha="center", va="bottom", fontsize=8.5, color="#222222",
            bbox=dict(boxstyle="round,pad=0.25", fc="white",
                      ec="#cccccc", alpha=0.85)
        )

    # Eje Y derecho: oculto, escala propia
    pad = falt_rng * 0.6
    ax2.set_ylim(falt.min() - pad, falt.max() + pad * 1.8)
    ax2.yaxis.set_visible(False)
    ax2.spines["right"].set_visible(False)
    ax2.spines["top"].set_visible(False)

    # Eje X
    ax1.set_xticks(x)
    ax1.set_xticklabels([m.strftime("%b-%Y") for m in meses],
                        rotation=45, ha="right", fontsize=9, color="#555")
    ax1.tick_params(axis="x", length=0)
    ax1.spines["bottom"].set_color("#dddddd")
    ax1.grid(axis="y", alpha=0.08, zorder=0)

    # Título
    ax1.set_title("Evolución mensual de Transacciones Faltantes",
                  fontsize=14, fontweight="bold", color="#333333", pad=14)

    # Leyenda
    handles = [
        mpatches.Patch(color=COLOR_UBA,    alpha=0.7, label="Txns UBA"),
        mpatches.Patch(color=COLOR_SBP,    alpha=0.7, label="Txns SBP"),
        Line2D([0],[0], color="#444", linewidth=1.8, label="Txns Faltantes"),
        Line2D([0],[0], marker="o", color="w", markerfacecolor=COLOR_OK,
               markersize=8, label="UBA ≥ SBP"),
        Line2D([0],[0], marker="o", color="w", markerfacecolor=COLOR_ALERTA,
               markersize=8, label="SBP > UBA"),
    ]
    ax1.legend(handles=handles, loc="upper center",
               bbox_to_anchor=(0.5, -0.22), ncol=5,
               frameon=False, fontsize=8.5)

    plt.tight_layout()
    plt.savefig(outfile, dpi=200, bbox_inches="tight", facecolor="white")
    plt.close()
    return os.path.abspath(outfile)
def plot_evolucion_diaria_ultimos_30_dias(df_full: pd.DataFrame,
                                          outfile: str = PNG_DIARIO30) -> str:
    """
    Gráfico de evolución diaria (últimos 30 días) de Txns Faltantes absolutas.
    Incluye:
      - Línea principal + puntos coloreados por relación UBA/SBP.
      - Línea horizontal de umbral fijo (0.5%).
      - Marcadores de outliers IQR (violeta) sobre los puntos anómalos.
      - Etiquetas de valor real en cada punto.
    """
    # --- Filtrar últimos 30 días ---
    df = df_full.copy()
    df["Fecha"] = pd.to_datetime(df["Fecha"], errors="coerce")
    if pd.api.types.is_datetime64tz_dtype(df["Fecha"]):
        df["Fecha"] = df["Fecha"].dt.tz_convert(None)
    df = df.dropna(subset=["Fecha"])

    hoy    = pd.Timestamp.today().normalize()
    inicio = hoy - pd.Timedelta(days=29)
    df     = df[(df["Fecha"] >= inicio) & (df["Fecha"] <= hoy)].sort_values("Fecha")

    if df.empty:
        return _grafico_vacio(outfile, "Sin datos en los últimos 30 días")

    # --- Calcular columnas auxiliares ---
    faltantes        = pd.to_numeric(df["Txns Faltantes"], errors="coerce")
    df["Falt Abs"]   = faltantes.abs()
    df["Relacion"]   = np.where(faltantes >= 0, "UBA ≥ SBP", "SBP > UBA")

    # Outliers IQR sobre el histórico completo
    outliers_mask    = detectar_outliers_iqr(df_full)
    df_full_c        = df_full.copy()
    df_full_c["Fecha"] = pd.to_datetime(df_full_c["Fecha"], errors="coerce")
    df_outliers      = df_full_c[outliers_mask].copy()
    df_outliers["Fecha"] = pd.to_datetime(df_outliers["Fecha"], errors="coerce")
    df_outliers      = df_outliers[
        (df_outliers["Fecha"] >= inicio) & (df_outliers["Fecha"] <= hoy)
    ].copy()
    df_outliers["Falt Abs"] = pd.to_numeric(
        df_outliers["Txns Faltantes"], errors="coerce"
    ).abs()

    # Umbral en unidades absolutas (aproximado: mediana de UBA * UMBRAL)
    paleta_pts = {"UBA ≥ SBP": COLOR_OK, "SBP > UBA": COLOR_ALERTA}

    p = (
        ggplot(df, aes(x="Fecha", y="Falt Abs")) +

        # Línea principal
        geom_line(color=COLOR_UBA, size=1.1) +

        # Puntos coloreados por relación
        geom_point(aes(color="Relacion"), size=3) +
        scale_color_manual(values=paleta_pts) +

        # Outliers IQR marcados con anillo violeta (si los hay)
        (
            geom_point(
                data    = df_outliers,
                mapping = aes(x="Fecha", y="Falt Abs"),
                color   = COLOR_OUTLIER,
                size    = 6,
                shape   = "o",
                fill    = "none",
                stroke  = 1.8,
            ) if not df_outliers.empty else geom_point(alpha=0)
        ) +

        # Etiquetas de valor
        geom_text(
            aes(label="Falt Abs"),
            format_string = "{:.0f}",
            nudge_y = df["Falt Abs"].max() * 0.05 if df["Falt Abs"].max() > 0 else 1,
            size    = 8,
            color   = "#333333",
        ) +

        scale_x_datetime(date_labels="%d-%b", date_breaks="2 days") +
        scale_y_continuous(labels=lambda lst: [f"{x:,.0f}" for x in lst]) +
        labs(title="Evolución diaria (últimos 30 días) de Transacciones Faltantes",
             caption=f"— — Umbral fijo {UMBRAL*100:.1f}%  |  ○ Outlier estadístico (IQR)") +
        _tema_corporativo() +
        theme(figure_size=(14, 6))
    )

    p.save(outfile, dpi=200, verbose=False)
    return os.path.abspath(outfile)




def plot_evolucion_diaria_30_log(df_full: pd.DataFrame,
                                  outfile: str = PNG_DIARIO30L) -> str:
    """
    Versión logarítmica del evolutivo diario 30 días con línea suavizada.
    Usa matplotlib directamente para control preciso del eje log y spline.

    Incluye:
      - Puntos coloreados por relación UBA/SBP
      - Línea suavizada (spline cúbico sobre valores absolutos)
      - Escala Y logarítmica base 10
      - Umbral IQR dinámico como línea punteada
      - Outliers IQR marcados con anillo violeta
    """
    import matplotlib.pyplot as plt
    import matplotlib.dates as mdates
    from scipy.interpolate import make_interp_spline

    df = df_full.copy()
    df["Fecha"] = pd.to_datetime(df["Fecha"], errors="coerce")
    if pd.api.types.is_datetime64tz_dtype(df["Fecha"]):
        df["Fecha"] = df["Fecha"].dt.tz_convert(None)
    df = df.dropna(subset=["Fecha"])

    hoy    = pd.Timestamp.today().normalize()
    inicio = hoy - pd.Timedelta(days=29)
    df     = df[(df["Fecha"] >= inicio) & (df["Fecha"] <= hoy)].sort_values("Fecha").reset_index(drop=True)

    if df.empty:
        return _grafico_vacio(outfile, "Sin datos en los últimos 30 días")

    faltantes      = pd.to_numeric(df["Txns Faltantes"], errors="coerce")
    df["Falt Abs"] = faltantes.abs()
    df["Relacion"] = np.where(faltantes >= 0, "UBA ≥ SBP", "SBP > UBA")

    # Umbral IQR dinámico
    serie_hist = pd.to_numeric(df_full["Txns Faltantes"], errors="coerce").abs()
    q1  = serie_hist.quantile(0.25)
    q3  = serie_hist.quantile(0.75)
    iqr = q3 - q1
    umbral_iqr = q3 + 1.5 * iqr

    # Outliers en ventana
    outliers_mask = detectar_outliers_iqr(df_full)
    df_full_c = df_full.copy()
    df_full_c["Fecha"] = pd.to_datetime(df_full_c["Fecha"], errors="coerce")
    df_out = df_full_c[outliers_mask].copy()
    df_out["Fecha"] = pd.to_datetime(df_out["Fecha"], errors="coerce")
    df_out = df_out[(df_out["Fecha"] >= inicio) & (df_out["Fecha"] <= hoy)].copy()
    df_out["Falt Abs"] = pd.to_numeric(df_out["Txns Faltantes"], errors="coerce").abs()

    fig, ax = plt.subplots(figsize=(14, 6), dpi=160)
    ax.set_facecolor("white")
    fig.patch.set_facecolor("white")

    # Escala log
    y_vals = df["Falt Abs"].values.astype(float)
    epsilon = max(y_vals[y_vals > 0].min() / 10, 1.0) if any(y_vals > 0) else 1.0
    y_plot  = np.where(y_vals > 0, y_vals, epsilon)

    fechas_num = mdates.date2num(df["Fecha"].dt.to_pydatetime())

    # Línea suavizada (spline cúbico, mínimo 4 puntos)
    if len(df) >= 4:
        try:
            x_smooth = np.linspace(fechas_num.min(), fechas_num.max(), 300)
            spl      = make_interp_spline(fechas_num, np.log10(y_plot), k=3)
            y_smooth = 10 ** spl(x_smooth)
            ax.plot(mdates.num2date(x_smooth), y_smooth,
                    color=COLOR_UBA, linewidth=1.8, alpha=0.6, zorder=2)
        except Exception:
            ax.plot(df["Fecha"], y_plot, color=COLOR_UBA, linewidth=1.8, alpha=0.6, zorder=2)
    else:
        ax.plot(df["Fecha"], y_plot, color=COLOR_UBA, linewidth=1.8, alpha=0.6, zorder=2)

    # Puntos por relación
    colores_pts = [COLOR_OK if r == "UBA ≥ SBP" else COLOR_ALERTA for r in df["Relacion"]]
    ax.scatter(df["Fecha"], y_plot, c=colores_pts, s=60, zorder=4)

    # Outliers con anillo violeta
    if not df_out.empty:
        y_out = np.where(df_out["Falt Abs"].values > 0,
                         df_out["Falt Abs"].values, epsilon)
        ax.scatter(df_out["Fecha"], y_out,
                   s=220, facecolors="none", edgecolors=COLOR_OUTLIER,
                   linewidths=2.0, zorder=5)

    # Umbral IQR como línea
    if umbral_iqr > 0:
        ax.axhline(umbral_iqr, color=COLOR_OUTLIER, linestyle="--",
                   linewidth=1.2, alpha=0.8,
                   label=f"Límite IQR ({umbral_iqr:,.0f})")

    # Etiquetas de valor
    for _, row in df.iterrows():
        yv = row["Falt Abs"] if row["Falt Abs"] > 0 else epsilon
        ax.annotate(f"{row['Falt Abs']:,.0f}",
                    xy=(row["Fecha"], yv),
                    xytext=(0, 8), textcoords="offset points",
                    ha="center", fontsize=7.5, color="#333333")

    ax.set_yscale("log", base=10)
    ax.yaxis.set_major_formatter(plt.FuncFormatter(
        lambda x, _: f"{x:,.0f}"
    ))
    ax.xaxis.set_major_locator(mdates.DayLocator(interval=2))
    ax.xaxis.set_major_formatter(mdates.DateFormatter("%d-%b"))
    plt.setp(ax.get_xticklabels(), rotation=45, ha="right", fontsize=9)

    ax.set_title("Evolución diaria (30 días) — escala logarítmica | línea suavizada",
                 fontsize=13, fontweight="bold", color="#333333")
    ax.set_xlabel("")
    ax.set_ylabel("")
    ax.tick_params(axis="y", labelleft=False, length=0)
    ax.grid(True, which="major", alpha=0.15)
    ax.grid(False, which="minor")

    # Leyenda manual
    from matplotlib.lines import Line2D
    from matplotlib.patches import Patch
    handles = [
        Patch(color=COLOR_OK,      label="UBA ≥ SBP"),
        Patch(color=COLOR_ALERTA,  label="SBP > UBA"),
        Line2D([0], [0], color=COLOR_OUTLIER, linestyle="--",
               label=f"Límite IQR ({umbral_iqr:,.0f})"),
        Line2D([0], [0], marker="o", color="w", markerfacecolor="none",
               markeredgecolor=COLOR_OUTLIER, markersize=10,
               label="Outlier IQR"),
    ]
    ax.legend(handles=handles, loc="upper center",
              bbox_to_anchor=(0.5, -0.18), ncol=4,
              frameon=False, fontsize=8)

    plt.tight_layout()
    plt.savefig(outfile, dpi=200, bbox_inches="tight", facecolor="white")
    plt.close()
    return os.path.abspath(outfile)

def _grafico_vacio(outfile: str, mensaje: str) -> str:
    """Genera un PNG en blanco con mensaje cuando no hay datos."""
    import matplotlib.pyplot as plt
    fig, ax = plt.subplots(figsize=(10, 4))
    ax.text(0.5, 0.5, mensaje, ha="center", va="center", fontsize=14)
    ax.axis("off")
    plt.savefig(outfile, dpi=150, bbox_inches="tight", facecolor="white")
    plt.close()
    return os.path.abspath(outfile)


# ==========================
# Resumen estadístico para correo
# ==========================
def _resumen_outlier_iqr(df_full: pd.DataFrame) -> str:
    """
    Genera texto HTML de alerta estadística si el último día es outlier IQR.
    Incluye el límite calculado para transparencia.
    """
    serie = pd.to_numeric(df_full["% Diferencia"], errors="coerce").abs() * 100
    q1    = serie.quantile(0.25)
    q3    = serie.quantile(0.75)
    iqr   = q3 - q1
    limite = q3 + 1.5 * iqr
    ultimo = serie.iloc[-1] if not serie.empty else 0.0

    if pd.notna(ultimo) and ultimo > limite:
        return (
            f'<p style="color:{COLOR_OUTLIER};font-weight:bold;">'
            f'⚠ Alerta estadística (IQR): La diferencia de hoy ({ultimo:.2f}%) '
            f'supera el límite estadístico ({limite:.2f}% = Q3 + 1.5×IQR). '
            f'Revisar causa raíz.'
            f'</p>'
        )
    return ""


# ==========================
# Helper: bloque HTML por fecha para el correo
# ==========================
def _bloque_resumen_fila(fila: pd.Series, df_full: pd.DataFrame) -> str:
    """
    Genera el bloque HTML de resumen para una sola fecha procesada.
    Incluye alerta de umbral fijo.
    """
    fecha_str = pd.to_datetime(fila["Fecha"]).strftime("%d/%m/%Y")
    uba       = int(fila["Txns UBA"])
    sbp       = int(fila["Txns SBP"])
    # Txns Faltantes y % Diferencia pueden ser None (son formulas Excel)
    # Se calculan desde UBA y SBP directamente para el correo
    falt      = uba - sbp
    pct       = (uba - sbp) / uba if uba != 0 else 0.0

    umbral_msg = (
        f'<span style="color:{COLOR_ALERTA};font-weight:bold;">'
        f'⚠ Superando el umbral del {UMBRAL*100:.1f}%.</span>'
        if abs(pct) > UMBRAL
        else f'<span style="color:{COLOR_OK};">✔ No se superó el umbral del {UMBRAL*100:.1f}%.</span>'
    )

    return f"""
    <p style="border-left:3px solid #1f77b4;padding-left:10px;margin-bottom:12px;">
      <b>Fecha: {fecha_str}</b><br/>
      Transacciones recibidas por UNIBANCA: <b>{sbp:,}</b><br/>
      Transacciones enviadas desde UNIBANCA: <b>{uba:,}</b><br/>
      Diferencia absoluta: <b>{abs(falt):,}</b> transacciones faltantes.<br/>
      Porcentaje de diferencia: <b>{abs(pct)*100:.3f}%</b><br/>
      {umbral_msg}
    </p>"""


# ==========================
# Envío de correo
# ==========================
def _add_inline_image(mail, img_path: str, cid: str) -> str:
    """Adjunta una imagen y asigna Content-ID para incrustarla en HTML."""
    attach = mail.Attachments.Add(Source=img_path)
    attach.PropertyAccessor.SetProperty(
        "http://schemas.microsoft.com/mapi/proptag/0x3712001E", cid
    )
    attach.PropertyAccessor.SetProperty(
        "http://schemas.microsoft.com/mapi/proptag/0x3713001E", cid
    )
    return cid


