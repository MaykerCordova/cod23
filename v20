def extract_tables_from_emails(df2: pd.DataFrame) -> None:
    """
    Extrae los conteos de transacciones de todos los correos pendientes
    en la carpeta Outlook, comparando contra la última fecha del Excel.

    Lógica robusta (reemplaza conteo fijo por día de semana):
      - Obtiene la última fecha registrada en el Excel.
      - Itera los correos de la carpeta (más recientes primero).
      - Solo procesa correos cuya fecha de datos > última fecha Excel.
      - Se detiene cuando encuentra un correo ya registrado (fecha ≤ última).
      - Agrupa pares UBA/SBP por fecha y construye las filas a insertar.
      - Funciona automáticamente para: día normal, lunes, feriados,
        ausencias de varios días — sin ninguna lógica manual adicional.

    Parameters
    ----------
    df2 : pd.DataFrame
        DataFrame de salida con las columnas del Excel destino.
        Se modificará in-place agregando una fila por cada fecha pendiente.
    """
    ultima_fecha    = _obtener_ultima_fecha_excel()
    specific_folder = _conectar_outlook_folder(FOLDER_NAME)

    items = specific_folder.Items

    # Filtrar en Outlook solo correos posteriores a ultima_fecha.
    # Outlook usa MM/DD/YYYY en el filtro Restrict.
    fecha_filtro = ultima_fecha + timedelta(days=1)
    fecha_filtro_str = fecha_filtro.strftime("%m/%d/%Y")
    items = items.Restrict(f"[ReceivedTime] >= '{fecha_filtro_str} 00:00 AM'")
    items.Sort("[ReceivedTime]", True)

    print(f"[INFO] Buscando correos con ReceivedTime >= {fecha_filtro_str}")
    print(f"[INFO] Correos encontrados: {items.Count}")

    # {fecha: {"UBA": int | None, "SBP": int | None}}
    buffer: dict[date, dict] = {}

    for item in items:
        try:
            if item.Class != 43:    # 43 = MailItem
                continue

            fecha_datos = (item.ReceivedTime - timedelta(days=1)).date()
            print(f"[DEBUG] {item.Subject[:40]} | fecha_datos: {fecha_datos}")

            if fecha_datos <= ultima_fecha:
                continue

            # Extraer número del body: buscar el último token numérico del texto
            try:
                palabras = item.Body.replace("\n", " ").replace(",", "").split()
                # Buscar de atrás hacia adelante el primer token convertible a int
                numero = None
                for palabra in reversed(palabras):
                    palabra_limpia = palabra.strip().rstrip(".")
                    if palabra_limpia.isdigit():
                        numero = int(palabra_limpia)
                        break
                if numero is None:
                    raise ValueError(f"No se encontró número en el body: {palabras[-6:]}")
                print(f"[DEBUG] Numero extraido: {numero} | fecha: {fecha_datos}")
            except Exception as ex:
                print(f"[DEBUG] Error extrayendo numero: {ex}")
                raise

            if fecha_datos not in buffer:
                buffer[fecha_datos] = {"UBA": None, "SBP": None}

            if item.Subject.startswith("RV: [External] Transacciones enviadas"):
                buffer[fecha_datos]["UBA"] = numero
            else:
                buffer[fecha_datos]["SBP"] = numero

        except (AttributeError, ValueError):
            continue

    # Construir filas solo para fechas con par UBA+SBP completo
    filas = []
    for fecha, datos in sorted(buffer.items()):
        uba = datos.get("UBA")
        sbp = datos.get("SBP")
        if uba is not None and sbp is not None:
            filas.append({
                "Fecha"          : fecha,
                "Txns UBA"       : uba,
                "Txns SBP"       : sbp,
                "% Diferencia"   : round((uba - sbp) / uba, 6) if uba != 0 else 0.0,  # =(UBA-SBP)/UBA
                "Txns Faltantes" : uba - sbp,                                           # =UBA-SBP
            })
        else:
            # Par incompleto: registrar advertencia pero no bloquear
            print(f"[AVISO] Fecha {fecha}: par incompleto "
                  f"(UBA={'OK' if uba else 'FALTA'}, "
                  f"SBP={'OK' if sbp else 'FALTA'}). Se omite.")

    if not filas:
        raise RuntimeError(
            f"No se encontraron correos pendientes después de {ultima_fecha}. "
            "Verificar carpeta Outlook o si el Excel ya está actualizado."
        )

    # Poblar df2 con todas las filas pendientes
    df2.drop(df2.index, inplace=True)
    for fila in filas:
        df2.loc[len(df2)] = fila

    print(f"[OK] {len(filas)} fecha(s) pendiente(s) procesada(s): "
          f"{[str(f['Fecha']) for f in filas]}")


# ==========================
# Análisis estadístico IQR
# ==========================
def detectar_outliers_iqr(df_full: pd.DataFrame) -> pd.Series:
    """
    Marca como outlier estadístico cualquier día donde |% Diferencia|
    supera Q3 + 1.5 * IQR.

    Parameters
    ----------
    df_full : pd.DataFrame
        Histórico completo.

    Returns
    -------
    pd.Series (bool)
        True donde el punto es outlier estadístico.
    """
    serie = pd.to_numeric(df_full["% Diferencia"], errors="coerce").abs() * 100
    q1  = serie.quantile(0.25)
    q3  = serie.quantile(0.75)
    iqr = q3 - q1
    limite_superior = q3 + 1.5 * iqr
    return serie > limite_superior


