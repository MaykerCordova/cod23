# =======================
# FUNCIÓN: INICIALIZAR METADATA DB
# =======================
def inicializar_metadata_db():
    conn = sqlite3.connect(METADATA_DB)
    cursor = conn.cursor()
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS archivos_procesados (
            archivo_nombre TEXT PRIMARY KEY,
            fecha_procesamiento TEXT,
            filas_procesadas INTEGER,
            ruta_completa TEXT,
            hash_archivo TEXT
        )
    ''')
    
    conn.commit()
    conn.close()

# =======================
# FUNCIÓN: CALCULAR HASH DE ARCHIVO
# =======================
def calcular_hash_archivo(filepath: Path) -> str:
    sha256 = hashlib.sha256()
    with open(filepath, 'rb') as f:
        for chunk in iter(lambda: f.read(4096), b''):
            sha256.update(chunk)
    return sha256.hexdigest()

# =======================
# FUNCIÓN: OBTENER ARCHIVOS PENDIENTES
# =======================
def obtener_archivos_pendientes() -> list:
    conn = sqlite3.connect(METADATA_DB)
    cursor = conn.cursor()
    cursor.execute('SELECT archivo_nombre, hash_archivo FROM archivos_procesados')
    procesados = {row[0]: row[1] for row in cursor.fetchall()}
    conn.close()
    
    csv_files = sorted(DATA_PATH.glob('*.csv'))
    pendientes = []
    
    for csv_file in csv_files:
        hash_actual = calcular_hash_archivo(csv_file)
        if csv_file.name not in procesados or procesados[csv_file.name] != hash_actual:
            pendientes.append(csv_file)
    
    return pendientes

# =======================
# FUNCIÓN: REGISTRAR ARCHIVO PROCESADO
# =======================
def registrar_archivo_procesado(archivo_path: Path, filas: int, hash_archivo: str):
    conn = sqlite3.connect(METADATA_DB)
    cursor = conn.cursor()
    
    cursor.execute('''
        INSERT OR REPLACE INTO archivos_procesados 
        (archivo_nombre, fecha_procesamiento, filas_procesadas, ruta_completa, hash_archivo)
        VALUES (?, ?, ?, ?, ?)
    ''', (
        archivo_path.name,
        datetime.now().isoformat(),
        filas,
        str(archivo_path),
        hash_archivo
    ))
    
    conn.commit()
    conn.close()

# =======================
# FUNCIÓN: DETECTAR ENCODING
# =======================
def detectar_encoding(csv_path: Path) -> str:
    """
    Intenta detectar el encoding correcto del CSV.
    Visa puede usar: utf-8-sig, latin-1, windows-1252, iso-8859-1
    """
    encodings = ['utf-8-sig', 'utf-8', 'latin-1', 'windows-1252', 'iso-8859-1']
    
    for encoding in encodings:
        try:
            with open(csv_path, 'r', encoding=encoding) as f:
                f.read(1000)  # Lee primeros 1000 caracteres
            print(f"      ✅ Encoding detectado: {encoding}")
            return encoding
        except UnicodeDecodeError:
            continue
    
    # Si todo falla, usar latin-1 (nunca falla pero puede dar caracteres raros)
    print(f"      ⚠️ Usando encoding por defecto: latin-1")
    return 'latin-1'

# =======================
# FUNCIÓN: LEER Y NORMALIZAR CSV
# =======================
def leer_csv_mar(csv_path: Path) -> pl.DataFrame:
    """
    Lee CSV de Visa MAR con detección automática de encoding y estructura.
    """
    print(f"   📄 Leyendo: {csv_path.name}")
    
    # Detectar encoding
    encoding = detectar_encoding(csv_path)
    
    # Leer CSV con encoding correcto
    try:
        df = pl.read_csv(
            str(csv_path),
            quote_char='"',
            infer_schema_length=10000,
            ignore_errors=False,
            encoding=encoding,
            has_header=True
        )
    except Exception as e:
        print(f"      ❌ Error leyendo CSV: {e}")
        print(f"      ⚙️ Intentando sin headers...")
        
        # Si falla, leer sin header y asignar nombres manualmente
        df = pl.read_csv(
            str(csv_path),
            quote_char='"',
            infer_schema_length=10000,
            ignore_errors=True,
            encoding=encoding,
            has_header=False
        )
    
    print(f"      Columnas detectadas: {df.columns}")
    print(f"      Total filas: {len(df)}")
    
    # =======================
    # NORMALIZACIÓN DE ESTRUCTURA
    # =======================
    # Caso 1: Si tiene headers normales
    if 'Product ID - Account' in df.columns:
        print(f"      ⚙️ Estructura: Headers estándar")
        
        # Renombrar
        col_mapping = {
            'Product ID - Account': 'Product_ID',
            'Issuer BIN': 'Issuer_BIN'
        }
        
        for old_name, new_name in col_mapping.items():
            if old_name in df.columns:
                df = df.rename({old_name: new_name})
        
        # Buscar columnas de Authorization
        auth_cols = [col for col in df.columns if 'Authorization' in col or 'Auth' in col]
        
        if len(auth_cols) >= 2:
            # Caso: código y descripción en columnas separadas
            df = df.rename({
                auth_cols[0]: 'Auth_Code',
                auth_cols[1]: 'Auth_Description'
            })
        elif len(auth_cols) == 1:
            # Caso: código y descripción juntos
            df = df.rename({auth_cols[0]: 'Auth_Response_Full'})
            
            df = df.with_columns([
                pl.col('Auth_Response_Full')
                  .str.extract(r'^(\d+)', 1)
                  .fill_null("")
                  .alias('Auth_Code'),
                
                pl.col('Auth_Response_Full')
                  .str.replace(r'^\d+\s*', '')
                  .fill_null("")
                  .alias('Auth_Description')
            ])
            df = df.drop('Auth_Response_Full')
        
        # Renombrar Date y Authorization Count
        if 'Date' in df.columns:
            pass  # Ya está bien
        
        if 'Authorization Count' in df.columns:
            df = df.rename({'Authorization Count': 'Authorization_Count'})
    
    # Caso 2: Sin headers o headers genéricos (column_1, column_2, etc.)
    else:
        print(f"      ⚙️ Estructura: Sin headers, asignando nombres...")
        
        # Asignar nombres basados en posición
        # Estructura esperada: Product_ID, Account, Issuer_BIN, Auth_Code, Auth_Description, Columna_Vacia?, Date, Authorization_Count
        
        num_cols = len(df.columns)
        
        if num_cols == 8:
            # Con columna vacía
            df.columns = [
                'Product_ID', 'Account', 'Issuer_BIN', 'Auth_Code', 
                'Auth_Description', 'Columna_Vacia', 'Date', 'Authorization_Count'
            ]
            df = df.drop('Columna_Vacia')
        elif num_cols == 7:
            # Sin columna vacía
            df.columns = [
                'Product_ID', 'Account', 'Issuer_BIN', 'Auth_Code',
                'Auth_Description', 'Date', 'Authorization_Count'
            ]
        elif num_cols == 6:
            # Sin Account
            df.columns = [
                'Product_ID', 'Issuer_BIN', 'Auth_Code',
                'Auth_Description', 'Date', 'Authorization_Count'
            ]
        else:
            print(f"      ⚠️ Número de columnas inesperado: {num_cols}")
            print(f"      Columnas: {df.columns}")
    
    # =======================
    # LIMPIEZA FINAL
    # =======================
    # Eliminar columnas completamente vacías
    cols_to_keep = []
    for col in df.columns:
        if not df[col].is_null().all():
            cols_to_keep.append(col)
    
    df = df.select(cols_to_keep)
    
    # Verificar que tenemos las columnas esenciales
    required_cols = ['Issuer_BIN', 'Auth_Code', 'Date', 'Authorization_Count']
    missing_cols = [col for col in required_cols if col not in df.columns]
    
    if missing_cols:
        print(f"      ❌ Faltan columnas requeridas: {missing_cols}")
        print(f"      Columnas disponibles: {df.columns}")
        raise ValueError(f"Columnas faltantes: {missing_cols}")
    
    # Tipado robusto
    df = df.with_columns([
        pl.col('Product_ID').cast(pl.Utf8).fill_null("Unknown") if 'Product_ID' in df.columns else pl.lit("Unknown").alias('Product_ID'),
        pl.col('Issuer_BIN').cast(pl.Utf8).str.strip_chars(),
        pl.col('Auth_Code').cast(pl.Utf8).str.strip_chars(),
        pl.col('Auth_Description').cast(pl.Utf8).str.strip_chars() if 'Auth_Description' in df.columns else pl.lit("").alias('Auth_Description'),
        pl.col('Date').str.strptime(pl.Date, '%d-%b-%Y', strict=False),
        pl.col('Authorization_Count').cast(pl.Int64)
    ])
    
    print(f"      ✅ Lectura exitosa: {len(df)} filas")
    return df

# =======================
# FUNCIÓN: COMPOSITE KEY
# =======================
def agregar_composite_key(df: pl.DataFrame) -> pl.DataFrame:
    df = df.with_columns(
        pl.concat_str([
            pl.col('Date').cast(pl.Utf8),
            pl.col('Issuer_BIN'),
            pl.col('Auth_Code'),
            pl.col('Authorization_Count').cast(pl.Utf8)
        ], separator='|').alias('composite_key')
    )
    
    df = df.with_columns(
        pl.col('composite_key')
          .map_elements(lambda x: hashlib.sha256(x.encode()).hexdigest(), return_dtype=pl.Utf8)
          .alias('row_hash')
    )
    
    return df

# =======================
# PASO 1: BRONZE
# =======================
def procesar_bronze(csv_path: Path):
    df_raw = leer_csv_mar(csv_path)
    
    fecha_carga = datetime.now().strftime('%Y%m%d_%H%M%S')
    df_raw = df_raw.with_columns([
        pl.lit(csv_path.name).alias('archivo_origen'),
        pl.lit(fecha_carga).alias('fecha_carga'),
        pl.lit(datetime.now().isoformat()).alias('timestamp_carga')
    ])
    
    bronze_file = BRONZE_PATH / f"mar_{csv_path.stem}_{fecha_carga}.parquet"
    df_raw.write_parquet(bronze_file)
    
    print(f"   ✅ Bronze: {bronze_file.name}")
    return df_raw

# =======================
# PASO 2: SILVER
# =======================
def procesar_silver(df_new: pl.DataFrame):
    silver_file = SILVER_PATH / 'mar_silver.parquet'
    
    if silver_file.exists():
        df_silver = pl.read_parquet(silver_file)
        print(f"   📂 Silver existente: {len(df_silver)} filas")
    else:
        df_silver = pl.DataFrame()
        print(f"   📂 Creando Silver nuevo")
    
    df_new = agregar_composite_key(df_new)
    
    if len(df_silver) > 0:
        df_silver = agregar_composite_key(df_silver)
        df_combined = pl.concat([df_silver, df_new])
    else:
        df_combined = df_new
    
    df_silver_updated = df_combined.unique(subset=['row_hash'], keep='last')
    df_silver_updated.write_parquet(silver_file)
    
    print(f"   ✅ Silver: {len(df_silver_updated)} filas totales")
    return df_silver_updated

# =======================
# PASO 3: GOLD
# =======================
def procesar_gold(df_silver: pl.DataFrame):
    df_gold = df_silver.select([
        'Date',
        'Product_ID',
        'Issuer_BIN',
        'Auth_Code',
        'Auth_Description',
        'Authorization_Count',
        'archivo_origen',
        'fecha_carga'
    ]).sort('Date', descending=True)
    
    gold_file = GOLD_PATH / 'mar_gold.parquet'
    df_gold.write_parquet(gold_file)
    
    print(f"   ✅ Gold: {len(df_gold)} filas")
    return df_gold

