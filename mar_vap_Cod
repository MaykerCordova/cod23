# EJECUCIÓN PRINCIPAL
# =======================
def main():
    print("\n" + "="*70)
    print("🚀 PIPELINE MAR - DECLINACIONES VISA")
    print("="*70)
    print(f"📅 Fecha: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"📂 Carpeta data: {DATA_PATH}")
    
    inicializar_metadata_db()
    archivos_pendientes = obtener_archivos_pendientes()
    
    if not archivos_pendientes:
        print("\n✅ No hay archivos nuevos para procesar")
        return
    
    print(f"\n📋 Archivos detectados: {len(archivos_pendientes)}")
    for idx, archivo in enumerate(archivos_pendientes, 1):
        print(f"   {idx}. {archivo.name}")
    
    print(f"\n🔄 Iniciando procesamiento...\n")
    
    total_filas = 0
    df_gold = None  # Inicializar variable
    
    for idx, csv_file in enumerate(archivos_pendientes, 1):
        print(f"{'─'*70}")
        print(f"📥 [{idx}/{len(archivos_pendientes)}] {csv_file.name}")
        print(f"{'─'*70}")
        
        try:
            df_bronze = procesar_bronze(csv_file)
            df_silver = procesar_silver(df_bronze)
            
            hash_archivo = calcular_hash_archivo(csv_file)
            registrar_archivo_procesado(csv_file, len(df_bronze), hash_archivo)
            
            total_filas += len(df_bronze)
            
        except Exception as e:
            print(f"   ❌ ERROR: {e}")
            import traceback
            traceback.print_exc()
            continue
    
    # Gold final
    if total_filas > 0:
        print(f"\n{'─'*70}")
        print(f"🏆 Generando Gold final...")
        print(f"{'─'*70}")
        
        silver_file = SILVER_PATH / 'mar_silver.parquet'
        if silver_file.exists():
            df_silver = pl.read_parquet(silver_file)
            df_gold = procesar_gold(df_silver)
    
    # Resumen
    print("\n" + "="*70)
    print("✅ PIPELINE COMPLETADO")
    print("="*70)
    print(f"📊 Archivos procesados: {len(archivos_pendientes)}")
    print(f"📊 Filas procesadas: {total_filas:,}")
    if df_gold is not None:
        print(f"📊 Total histórico: {len(df_gold):,} filas")
        print(f"\n💡 Conecta Power BI a: {GOLD_PATH / 'mar_gold.parquet'}")
    else:
        print(f"\n⚠️ No se generó archivo Gold (verificar errores arriba)")

if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n⚠️ Proceso interrumpido")
    except Exception as e:
        print(f"\n❌ ERROR CRÍTICO: {e}")
