print("\n" + "="*70)
print("1. CARGANDO Y PREPARANDO DATA")
print("="*70)

df = pd.read_csv(RUTA_8750, encoding="latin-1", low_memory=False)

# Renombrar columnas — solo las que existen
rename_map = {v: k for k, v in COLUMNAS.items() if v in df.columns}
df = df.rename(columns=rename_map)

# Parsear datetime
if "fecha_trx" in df.columns and "hora_trx" in df.columns:
    df["datetime_trx"] = pd.to_datetime(
        df["fecha_trx"].astype(str) + " " + df["hora_trx"].astype(str),
        format="%Y-%m-%d %H:%M:%S",
        errors="coerce"
    )
elif "fecha_trx" in df.columns:
    df["datetime_trx"] = pd.to_datetime(df["fecha_trx"], errors="coerce")

# Monto a float
df["monto"] = pd.to_numeric(df["monto"], errors="coerce")

# Variable objetivo: F=1, resto=0
df["es_fraude"] = (df["indicador_fraude"] == "F").astype(int)

total_fraudes  = df["es_fraude"].sum()
total_trx      = len(df)
monto_fraude_total = df.loc[df["es_fraude"] == 1, "monto"].sum()

print(f"  Filas totales      : {total_trx:,}")
print(f"  Fraudes (F)        : {total_fraudes:,}")
print(f"  Fraud rate global  : {total_fraudes/total_trx*100:.3f}%")
print(f"  Monto total fraude : S/ {monto_fraude_total:,.0f}")


# ──────────────────────────────────────────────────────────────────────────────
# 2. DISTRIBUCIÓN POR INDICADOR DE FRAUDE
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("2. DISTRIBUCIÓN POR INDICADOR DE FRAUDE")
print("   F=Fraude | N=Normal | G=Good | D=Descarte | P=Pendiente")
print("="*70)

resumen_ind = (
    df.groupby("indicador_fraude")
      .agg(
          n_trx        = ("monto", "count"),
          n_clientes   = ("cliente_id", "nunique"),
          monto_total  = ("monto", "sum"),
          monto_prom   = ("monto", "mean"),
          monto_mediana= ("monto", "median"),
          monto_maximo = ("monto", "max"),
      )
      .reset_index()
)
resumen_ind["pct_trx"]   = (resumen_ind["n_trx"]   / resumen_ind["n_trx"].sum()   * 100).round(2)
resumen_ind["pct_monto"] = (resumen_ind["monto_total"] / resumen_ind["monto_total"].sum() * 100).round(2)
resumen_ind = resumen_ind.sort_values("monto_total", ascending=False)
print(resumen_ind.to_string(index=False))


# ──────────────────────────────────────────────────────────────────────────────
# 3. INGENIERÍA DE VARIABLES
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("3. CONSTRUYENDO FEATURES")
print("="*70)

# Ordenar por cliente y tiempo — CRÍTICO para rolling
df = df.sort_values(["cliente_id", "datetime_trx"]).reset_index(drop=True)

# ── 3.1 Temporales ────────────────────────────────────────────────────────────
df["hora"]       = df["datetime_trx"].dt.hour
df["dia_semana"] = df["datetime_trx"].dt.dayofweek   # 0=Lun, 6=Dom

df["flag_nocturno"]   = ((df["hora"] >= 22) | (df["hora"] <= 6)).astype(int)
df["flag_fin_semana"] = (df["dia_semana"] >= 5).astype(int)
df["hora_sin"]        = np.sin(2 * np.pi * df["hora"] / 24)
df["hora_cos"]        = np.cos(2 * np.pi * df["hora"] / 24)

# ── 3.2 Tiempo desde última trx del cliente (segundos) ───────────────────────
df["seg_desde_ultima_trx"] = (
    df.groupby("cliente_id")["datetime_trx"]
      .diff()
      .dt.total_seconds()
)

# ── 3.3 Saldo disponible — PENDIENTE ─────────────────────────────────────────
# Cuando tengas saldo_disponible, descomenta y elimina los NaN:
# df["ratio_monto_saldo"] = df["monto"] / (df["saldo_disponible"] + 1)
# df["flag_vaciado"]      = (df["ratio_monto_saldo"] > 0.85).astype(int)
df["ratio_monto_saldo"] = np.nan
df["flag_vaciado"]      = 0

# ── 3.4 Banco destino de riesgo ───────────────────────────────────────────────
df["flag_dest_riesgo"] = (
    df["banco_destino"].str.upper().str.contains(BANCO_RIESGO, na=False)
).astype(int)

# ── 3.5 Primera vez que cliente transfiere a esta cuenta destino ──────────────
df["es_primera_vez_destino"] = (
    ~df.duplicated(subset=["cliente_id", "cuenta_destino"], keep="first")
).astype(int)

# ── 3.6 Cuentas mula — cuántos clientes distintos recibió esa cuenta ─────────
receptores = (
    df.groupby("cuenta_destino")
      .agg(
          n_clientes_a_cuenta_destino = ("cliente_id", "nunique"),
          monto_total_recibido_cuenta = ("monto", "sum"),
      )
      .reset_index()
)
df = df.merge(receptores, on="cuenta_destino", how="left")

# ── 3.7 Ventanas de velocidad rolling ────────────────────────────────────────
# Usamos índice datetime por cliente para rolling temporal
ventanas = {
    "3min": "3min",
    "5min": "5min",
    "1h":   "1h",
    "12h":  "12h",
    "24h":  "24h",
}

# Guardamos índice original para reordenar al final
df["_idx_orig"] = df.index

for nombre, ventana in ventanas.items():
    print(f"  Calculando ventana {nombre}...")
    resultado = []
    for cliente, grupo in df.groupby("cliente_id"):
        g = grupo.set_index("datetime_trx").sort_index()
        roll = g["monto"].rolling(window=ventana, min_periods=1)
        n_trx    = roll.count().astype(int)
        monto_ac = roll.sum()
        tmp = pd.DataFrame({
            "_idx_orig":          g["_idx_orig"].values,
            f"n_trx_{nombre}":    n_trx.values,
            f"monto_acum_{nombre}": monto_ac.values,
        })
        resultado.append(tmp)

    res_df = pd.concat(resultado).set_index("_idx_orig")
    df = df.set_index("_idx_orig").join(res_df).reset_index(drop=True)

print("  ✓ Ventanas rolling construidas")

# ── 3.8 Ratio monto vs promedio del segmento ──────────────────────────────────
avg_seg = df.groupby("segmento")["monto"].mean().rename("avg_monto_segmento")
df = df.join(avg_seg, on="segmento")
df["ratio_monto_vs_segmento"] = df["monto"] / (df["avg_monto_segmento"] + 1)

# ── 3.9 Método de autenticación — PENDIENTE ───────────────────────────────────
