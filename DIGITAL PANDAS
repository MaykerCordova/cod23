# 6. EVALUACIÓN DE REGLAS DE CONTROL
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("6. EVALUACIÓN DE REGLAS DE CONTROL")
print("="*70)

def evaluar_regla(df, nombre, mascara):
    tp      = int(( mascara & (df["es_fraude"] == 1)).sum())
    fp      = int(( mascara & (df["es_fraude"] == 0)).sum())
    total_f = int(df["es_fraude"].sum())
    total_a = tp + fp
    prec    = tp / (total_a  + 1e-10)
    rec     = tp / (total_f  + 1e-10)
    f1      = 2 * prec * rec / (prec + rec + 1e-10)
    monto_c = df.loc[mascara & (df["es_fraude"] == 1), "monto"].sum()
    monto_tf= df.loc[df["es_fraude"] == 1, "monto"].sum()
    print(f"\n  {'─'*55}")
    print(f"  Regla    : {nombre}")
    print(f"  Alertas  : {total_a:,}  ({total_a/len(df)*100:.1f}% del universo)")
    print(f"  Recall   : {rec*100:.1f}%  ({tp:,} de {total_f:,} fraudes capturados)")
    print(f"  Precision: {prec*100:.1f}%  |  F1: {f1:.3f}")
    print(f"  FP (normales afectados) : {fp:,}")
    print(f"  Monto fraude capturado  : S/ {monto_c:,.0f}  ({monto_c/monto_tf*100:.1f}% del total)")

evaluar_regla(df, "R1 — Banco destino riesgo",
    df["flag_dest_riesgo"] == 1)

evaluar_regla(df, "R2 — Rafaga >= 2 trx en 5 min",
    df["n_trx_5min"] >= 2)

evaluar_regla(df, "R3 — Banco riesgo + primera vez a esa cuenta",
    (df["flag_dest_riesgo"] == 1) & (df["es_primera_vez_destino"] == 1))

evaluar_regla(df, "R4 — Rafaga 5min + banco riesgo",
    df["flag_rafaga_dest_riesgo"] == 1)

evaluar_regla(df, "R5 — Triple señal (rafaga + nocturno + banco riesgo)",
    df["flag_alto_riesgo"] == 1)

evaluar_regla(df, "R6 — OR combinado: R3 + R4",
    ((df["flag_dest_riesgo"] == 1) & (df["es_primera_vez_destino"] == 1)) |
    (df["flag_rafaga_dest_riesgo"] == 1))

