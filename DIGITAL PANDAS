# ── 5b. Umbral combinado: monto >= X AND banco destino riesgo ─────────────────
print("\n── UMBRALES COMBINADOS: monto >= X  AND  banco destino riesgo ───────")
print("   Más quirúrgico — solo afecta trx hacia el banco de riesgo\n")

filas_uc = []
for u in UMBRALES:
    sub = df[(df["monto"] >= u) & (df["flag_dest_riesgo"] == 1)]
    if len(sub) == 0:
        continue
    nf = sub["es_fraude"].sum()
    nn = len(sub) - nf
    mc = sub.loc[sub["es_fraude"] == 1, "monto"].sum()
    filas_uc.append({
        "umbral_S/":            u,
        "fraudes_capturados":   int(nf),
        "recall_fraude_%":      round(nf / (total_fraudes + 1e-10) * 100, 1),
        "monto_fraude_cap_S/":  round(mc, 0),
        "normales_afectados":   int(nn),
        "precision_%":          round(nf / (len(sub) + 1e-10) * 100, 2),
    })

tabla_uc = pd.DataFrame(filas_uc)
print(tabla_uc.to_string(index=False))


