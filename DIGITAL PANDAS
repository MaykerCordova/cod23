        "recall_fraude_%":      round(nf / (total_fraudes + 1e-10) * 100, 1),
        "monto_fraude_cap_S/":  round(mc, 0),
        "pct_monto_fraude_%":   round(mc / monto_fraude_total * 100, 1),
        "normales_afectados":   int(nn),
        "pct_normales_afect_%": round(nn / (total_normales + 1e-10) * 100, 1),
        "precision_%":          round(nf / (len(sub) + 1e-10) * 100, 2),
    })

tabla_umbrales = pd.DataFrame(filas_u)
print(tabla_umbrales.to_string(index=False))
print(f"\n  Referencia — Total fraudes  : {total_fraudes:,}")
print(f"  Referencia — Total normales : {total_normales:,}")
