# df["flag_auth_debil"] = df["codigo_auth"].isin(["SM", "EM", ""]).astype(int)

# ── 3.10 Features compuestas ──────────────────────────────────────────────────
df["flag_rafaga_dest_riesgo"] = (
    (df["n_trx_5min"] >= 2) & (df["flag_dest_riesgo"] == 1)
).astype(int)

df["flag_alto_riesgo"] = (
    (df["n_trx_5min"] >= 2) &
    (df["flag_nocturno"] == 1) &
    (df["flag_dest_riesgo"] == 1)
).astype(int)

# Pendiente saldo:
df["flag_vaciado_cuenta_nueva"] = 0
