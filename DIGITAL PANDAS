#     (df["flag_vaciado"] == 1) & (df["es_primera_vez_destino"] == 1)
# ).astype(int)

print(f"  ✓ Todas las features construidas — {df.shape[1]} columnas totales")


# ──────────────────────────────────────────────────────────────────────────────
# 4. DISCRIMINACIÓN DE FEATURES BINARIAS
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("4. DISCRIMINACIÓN DE FEATURES BINARIAS")
print("   Lift > 1  →  concentra más fraude que el promedio global")
print("   Lift = 3  →  3x más probable que sea fraude cuando flag = 1")
print("="*70)

flags = [
    "flag_nocturno",
    "flag_fin_semana",
    "flag_dest_riesgo",
    "es_primera_vez_destino",
    "flag_rafaga_dest_riesgo",
    "flag_alto_riesgo",
    # "flag_vaciado",               # pendiente saldo
    # "flag_vaciado_cuenta_nueva",  # pendiente saldo
    # "flag_auth_debil",            # pendiente nombre_comercio
]

filas_disc = []
for flag in flags:
    if flag not in df.columns:
        continue
    grp = df.groupby(flag).agg(
        n_trx        = ("es_fraude", "count"),
        n_fraudes    = ("es_fraude", "sum"),
        fraud_rate   = ("es_fraude", "mean"),
        monto_fraude = ("monto", lambda x: x[df.loc[x.index, "es_fraude"] == 1].sum()),
    ).reset_index()

    f1 = grp[grp[flag] == 1]
    f0 = grp[grp[flag] == 0]
    if f1.empty or f0.empty:
        continue

    fr1 = f1["fraud_rate"].values[0]
    fr0 = f0["fraud_rate"].values[0]
    filas_disc.append({
        "feature":              flag,
        "fraud_rate_flag1_%":   round(fr1 * 100, 3),
        "fraud_rate_flag0_%":   round(fr0 * 100, 3),
        "lift":                 round(fr1 / (fr0 + 1e-10), 2),
        "n_trx_alertadas":      int(f1["n_trx"].values[0]),
        "fraudes_capturados":   int(f1["n_fraudes"].values[0]),
        "monto_fraude_cap_S/":  round(f1["monto_fraude"].values[0], 0),
    })

disc_df = pd.DataFrame(filas_disc).sort_values("lift", ascending=False)
print(disc_df.to_string(index=False))


