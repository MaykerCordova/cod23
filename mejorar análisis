@st.cache_data
def generate_synthetic(n=6000, seed=42):
    np.random.seed(seed); rng = np.random.default_rng(seed)
    from datetime import timedelta

    comercios = ["AMAZON","MERCADO_LIBRE","RAPPI","UBER","NETFLIX",
                 "FALABELLA","SAGA","WONG","PLAZAVEA","COMERCIO_X",
                 "GOOGLE_PLAY","ALIEXPRESS"]
    mccs   = ["5411","5812","7372","4816","5999","6011","7011","5945"]
    canales= ["INT","POS","ATM","CONTACTLESS"]
    entries= list(ENTRY_MODE.keys())
    segs   = list(SEGMENTO.keys())
    paises = ["PE","PER","US","CL","CO","MX","BR"]
    p_pais = [0.50,0.20,0.10,0.05,0.05,0.05,0.05]

    bins_norm = [f"4{rng.integers(10000,99999)}" for _ in range(20)]
    bins_comp = ["422052","423011","430150"]
    all_bins  = bins_norm + bins_comp

    base   = datetime(2024,10,1)
    fechas = [base + timedelta(seconds=int(x))
              for x in rng.integers(0,86400*90,n)]

    comercio_arr = rng.choice(comercios, n)
    bin_arr = []
    for c in comercio_arr:
        if c in ["COMERCIO_X","RAPPI","ALIEXPRESS"]:
            w = np.array([0.05]*20+[0.30,0.25,0.20]); w/=w.sum()
        else:
            w = np.array([1/23]*23)
        bin_arr.append(rng.choice(all_bins, p=w))

    montos = np.where(np.isin(bin_arr,bins_comp),
                      rng.lognormal(4.6,1.3,n),
                      rng.lognormal(4.0,0.8,n)).round(2)

    p = np.where(np.isin(bin_arr,["422052"]),0.38,
        np.where(np.isin(bin_arr,["423011"]),0.28,
        np.where(np.isin(bin_arr,["430150"]),0.20,
        np.where(np.isin(comercio_arr,["COMERCIO_X"]),0.22,
        np.where(np.isin(comercio_arr,["RAPPI","ALIEXPRESS"]),0.16,0.04)))))
    p = np.clip(p+(montos>500)*0.08,0,0.92)

    rand = rng.uniform(0,1,n)
    ind  = np.where(rand<p,"F",
           np.where(rand<p+0.12,"G",
           np.where(rand<p+0.17,"D",
           np.where(rand<p+0.20,"P","N"))))

    cods   = ["00","N7","04","14","51","59","53","69","05","12"]
    c_prob = [0.50,0.10,0.04,0.04,0.08,0.06,0.04,0.04,0.05,0.05]

    return pd.DataFrame({
        "acf_fecha_trx":    [f.strftime("%Y%m%d") for f in fechas],
        "acf_hora_trx":     [f.strftime("%H:%M:%S") for f in fechas],
        "acf_monto_en_moneda_local": montos,
        "acf_nombre_comercio": comercio_arr,
        "acf_mcc_":         rng.choice(mccs,n),
        "acf_bin":          bin_arr,
        "acf_tarjeta_registro_750": [f"{rng.integers(1000,9999)}" for _ in range(n)],
        "acf_canal":        rng.choice(canales,n,p=[0.42,0.33,0.15,0.10]),
        "acf_entry_mode":   rng.choice(entries,n),
        "acf_indicador_de_fraude": ind,
        "acf_cod_red_comercio": rng.choice(["S","D","E","N",""],n,
                                            p=[0.20,0.30,0.15,0.15,0.20]),
        "acf_tipo_prod_tc": rng.choice(["TC","TD"],n,p=[0.55,0.45]),
        "acf_id_cliente":   [f"0000{rng.integers(10000000,99999999)}" for _ in range(n)],
