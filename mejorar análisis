@st.cache_data
def preprocess(df):
    df = df.copy()

    # ── Fecha + hora → datetime ───────────────────────────────────────
    # Tu Monitor: fecha=YYYYMMDD en una col, hora=HH:MM:SS en otra
    col_f = next((c for c in df.columns if "fecha_trx" in c), None)
    col_h = next((c for c in df.columns if "hora_trx"  in c), None)

    if col_f and col_h:
        df["fecha_hora"] = pd.to_datetime(
            df[col_f].astype(str).str.strip() + " " +
            df[col_h].astype(str).str.strip(),
            format="%Y%m%d %H:%M:%S", errors="coerce")
    elif col_f:
        df["fecha_hora"] = pd.to_datetime(df[col_f].astype(str),
                                           errors="coerce")

    # ── Monto ─────────────────────────────────────────────────────────
    col_m = next((c for c in df.columns if "monto_en_moneda" in c), None)
    df["monto"] = pd.to_numeric(df[col_m], errors="coerce").fillna(0) if col_m else 0.0

    # ── Indicador / target ────────────────────────────────────────────
    col_ind = next((c for c in df.columns if "indicador_de_fraude" in c), None)
    df["indicador"] = df[col_ind].astype(str).str.strip().str.upper() if col_ind else "N"
    df["fraude_bin"] = (df["indicador"]=="F").astype(int)
    df["label_tipo"] = df["indicador"].map({
        "F":"positivo_confirmado","G":"negativo_confirmado",
        "D":"negativo_probable",  "N":"unlabeled","P":"excluir"
    }).fillna("unlabeled")

    # ── Comercio ──────────────────────────────────────────────────────
    col_com = next((c for c in df.columns if "nombre_comercio" in c), None)
    df["comercio"] = df[col_com].astype(str).str.strip().str.upper() if col_com else "SIN_COMERCIO"

    # ── BIN ───────────────────────────────────────────────────────────
    col_bin = next((c for c in df.columns if c == "acf_bin"), None)
    df["bin"] = df[col_bin].astype(str).str.strip() if col_bin else "000000"

    # ── Tarjeta ───────────────────────────────────────────────────────
    col_tar = next((c for c in df.columns if "tarjeta_registro" in c), None)
    df["tarjeta"] = df[col_tar].astype(str) if col_tar else df.index.astype(str)

    # ── CVV / Red de comercio ─────────────────────────────────────────
    col_cvv = next((c for c in df.columns
                    if "cod_red_comercio" in c and "resp" not in c and "cod_" not in c[:8]), None)
    if col_cvv:
        df["cvv_tipo"]        = df[col_cvv].astype(str).str.strip().map(CVV_TIPO).fillna("Desconocido")
        df["es_cvv_dinamico"] = (df[col_cvv].astype(str).str.strip()=="D").astype(int)
        df["es_sin_cvv"]      = df[col_cvv].astype(str).str.strip().isin(["","0","000000","N"]).astype(int)

    # ── Entry mode → CP/CNP ───────────────────────────────────────────
    col_em = next((c for c in df.columns if "entry_mode" in c), None)
    if col_em:
        df["entry_mode_clean"] = df[col_em].astype(str).str.strip().str.zfill(2)
        df["ambiente"]     = df["entry_mode_clean"].map(
            lambda x: ENTRY_MODE.get(x,{}).get("ambiente","?"))
        df["entry_riesgo"] = df["entry_mode_clean"].map(
            lambda x: ENTRY_MODE.get(x,{}).get("riesgo","?"))
        df["es_cnp"]       = (df["ambiente"]=="CNP").astype(int)
        df["es_fallback"]  = (df["entry_mode_clean"]=="81").astype(int)

    # ── Segmento ──────────────────────────────────────────────────────
    col_seg = next((c for c in df.columns if "evento_de_compromiso" in c), None)
    if col_seg:
        df["segmento_nom"] = df[col_seg].astype(str).str.strip().map(SEGMENTO).fillna("Otros")

    # ── País → Doméstico/Internacional ───────────────────────────────
    col_pais = next((c for c in df.columns if "pais_origen" in c), None)
    if col_pais:
        df["es_internacional"] = (~df[col_pais].astype(str).str.strip().isin(PAIS_DOM)).astype(int)

    # ── Wallet ────────────────────────────────────────────────────────
    col_alf = next((c for c in df.columns if "reservado_alfa" in c), None)
    if col_alf:
        df["wallet"]    = df[col_alf].astype(str).str.strip().str[:5].map(WALLET).fillna("Sin wallet")
        df["es_wallet"] = (df["wallet"]!="Sin wallet").astype(int)

    # ── ECI → comercio seguro ─────────────────────────────────────────
    col_eci = next((c for c in df.columns if "eci" in c), None)
    if col_eci:
        df["es_comercio_seguro"] = df[col_eci].astype(str).str.strip().isin(ECI_SEGURO).astype(int)

    # ── Recurrente ────────────────────────────────────────────────────
    col_rec = next((c for c in df.columns
                    if "indicador_bajo_recurrente" in c or
                    ("recurrente" in c and "operaciones" not in c)), None)
    if col_rec:
        df["es_recurrente"] = (df[col_rec].astype(str).str.strip().str.upper()=="R").astype(int)

    # ── Código de respuesta ───────────────────────────────────────────
    col_cod = next((c for c in df.columns
                    if "cod_resp" in c or "codigo_respuesta" in c), None)
    if col_cod:
        df["cod_resp"]         = df[col_cod].astype(str).str.strip()
        df["es_n7"]            = (df["cod_resp"]=="N7").astype(int)
        df["es_robada"]        = (df["cod_resp"]=="04").astype(int)
        df["es_invalida"]      = (df["cod_resp"]=="14").astype(int)
        df["es_regla_interna"] = df["cod_resp"].isin(["59","53","69"]).astype(int)
        df["fue_aprobada"]     = (df["cod_resp"]=="00").astype(int)
        df["es_critico_resp"]  = df["cod_resp"].isin(["N7","04","14"]).astype(int)

    # ── Tipo producto ─────────────────────────────────────────────────
    col_tp = next((c for c in df.columns if "tipo_prod" in c), None)
    if col_tp:
        df["es_credito"] = (df[col_tp].astype(str).str.upper()=="TC").astype(int)

    # ── Score original ────────────────────────────────────────────────
    col_sc = next((c for c in df.columns if c=="score_de_riesgo"), None)
    if col_sc:
        df["score_riesgo_orig"] = pd.to_numeric(df[col_sc],errors="coerce").fillna(0)

    # ── Hora del día ──────────────────────────────────────────────────
    if "fecha_hora" in df.columns:
        df["hora_dia"]     = df["fecha_hora"].dt.hour
        df["es_madrugada"] = df["hora_dia"].between(0,5).astype(int)
        df["es_noche"]     = df["hora_dia"].between(20,23).astype(int)

    if "fecha_hora" in df.columns:
        df = df.sort_values("fecha_hora").reset_index(drop=True)
    return df


