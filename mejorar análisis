def clean_names(df):
    if HAS_JANITOR:
        return df.clean_names()
    df.columns = (df.columns.str.strip().str.lower()
                  .str.replace(r"[^\w\s]","",regex=True)
                  .str.replace(r"\s+","_",regex=True)
                  .str.replace(r"_+","_",regex=True)
                  .str.strip("_"))
    return df


def load_file(path_or_buf, skip_rows=4, apply_janitor=True, is_path=True):
    try:
        name = path_or_buf if is_path else getattr(path_or_buf,"name","")
        if str(name).lower().endswith((".xlsx",".xls")):
            # Primera pasada: detectar columnas
            df_hdr = pd.read_excel(path_or_buf if is_path else path_or_buf,
                                   skiprows=skip_rows, engine="openpyxl", nrows=0)
            if apply_janitor:
                df_hdr = clean_names(df_hdr)
            dtype_map = {c: str   for c in df_hdr.columns if c in COLS_STR}
            dtype_map.update({c: float for c in df_hdr.columns if c in COLS_NUM})

            # Segunda pasada: carga real
            if not is_path:
                path_or_buf.seek(0)
            df = pd.read_excel(path_or_buf, skiprows=skip_rows,
                               engine="openpyxl", dtype=dtype_map)
        else:
            df = pd.read_csv(path_or_buf, skiprows=skip_rows,
                             encoding="latin-1", dtype=str)
            for c in COLS_NUM:
                if c in df.columns:
                    df[c] = pd.to_numeric(df[c], errors="coerce")

        if apply_janitor:
            df = clean_names(df)

        # Limpiar strings residuales (.0 en MCC, espacios, "nan")
        for c in COLS_STR:
            if c in df.columns:
                df[c] = (df[c].astype(str).str.strip()
                              .str.replace(r"\.0$","",regex=True)
                              .replace("nan",""))
        return df
    except Exception as e:
        st.error(f"Error al cargar: {e}"); return None

