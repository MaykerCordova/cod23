FEATURES_BASE = ["monto","fr_comercio","monto_medio","zscore_monto",
                 "bin_fr","poc_flag","velocity_flag"]
FEATURES_OPT  = ["ratio_n7","ratio_critico","ratio_cnp","ratio_fallback",
                 "es_n7","es_robada","es_invalida","es_regla_interna",
                 "fue_aprobada","es_cnp","es_fallback","es_cvv_dinamico",
                 "es_sin_cvv","es_internacional","es_wallet","es_recurrente",
                 "es_madrugada","es_noche","es_comercio_seguro","es_credito",
                 "score_riesgo_orig"]


@st.cache_data
def train_models(df, tree_depth):
    feats = [f for f in FEATURES_BASE+FEATURES_OPT if f in df.columns]
    df_tr = df[df["label_tipo"].isin([
        "positivo_confirmado","negativo_confirmado","negativo_probable"])].copy()
    df_tr["target"] = (df_tr["label_tipo"]=="positivo_confirmado").astype(int)
    sw = np.where(df_tr["label_tipo"]=="negativo_probable",0.5,1.0)

    X = df_tr[feats].fillna(0); y = df_tr["target"]
    empty_metrics = dict(teacher_auc=0,lr_auc=0,student_auc=0,
                         teacher_name="N/A",y_te=[],t_proba=[],l_proba=[],
                         feats=feats,intercept=0)

    if y.nunique()<2 or len(y)<50:
        df["prob_fraude"]=0.0; df["prob_fraude_lr"]=0.0
        return df, pd.DataFrame(), "", empty_metrics

    X_tr,X_te,y_tr,y_te,sw_tr,_ = train_test_split(
        X,y,sw, test_size=0.25, stratify=y, random_state=42)

    # Teacher
    if HAS_LGB:
        teacher = lgb.LGBMClassifier(n_estimators=200,learning_rate=0.05,
                                      num_leaves=31,class_weight="balanced",
                                      random_state=42,verbose=-1)
    else:
        teacher = RandomForestClassifier(n_estimators=200,class_weight="balanced",
                                          random_state=42,n_jobs=-1)
    teacher.fit(X_tr,y_tr,sample_weight=sw_tr)
    t_proba = teacher.predict_proba(X_te)[:,1]
    t_auc   = roc_auc_score(y_te,t_proba)
    df["prob_fraude"] = teacher.predict_proba(df[feats].fillna(0))[:,1]

    # Regresión Logística
    sc = StandardScaler()
    lr = LogisticRegression(class_weight="balanced",max_iter=500,random_state=42)
    lr.fit(sc.fit_transform(X_tr),y_tr,sample_weight=sw_tr)
    l_proba = lr.predict_proba(sc.transform(X_te))[:,1]
    l_auc   = roc_auc_score(y_te,l_proba)
    df["prob_fraude_lr"] = lr.predict_proba(sc.transform(df[feats].fillna(0)))[:,1]

    # Árbol destilado
    soft    = (df.loc[df_tr.index,"prob_fraude"]>0.40).astype(int)
    student = DecisionTreeClassifier(max_depth=tree_depth,
                                      class_weight="balanced",random_state=42)
    student.fit(X_tr, soft[X_tr.index])
    s_auc = roc_auc_score(y_te, student.predict_proba(X_te)[:,1])

    coef_df  = pd.DataFrame({"variable":feats,"coeficiente":lr.coef_[0]})\
                 .sort_values("coeficiente",key=abs,ascending=False)
    tree_txt = export_text(student, feature_names=feats)
    metrics  = dict(teacher_auc=t_auc,lr_auc=l_auc,student_auc=s_auc,
                    teacher_name="LightGBM" if HAS_LGB else "RandomForest",
                    y_te=y_te,t_proba=t_proba,l_proba=l_proba,
                    feats=feats,intercept=lr.intercept_[0])
    return df, coef_df, tree_txt, metrics


