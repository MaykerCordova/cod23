]
cols_show = [c for c in cols_show if c in df_cliente.columns
]
display(df_cliente[cols_show
].reset_index(drop=True))

print("\n→ Verifica que el bucket del día (columna 'Bucket_dia') coincida")
print("  con el intervalo de la Hoja 5 del Excel para este cliente")

