]
print(f"  Promedio:  S/ {dias_sin_fraude['Monto_dia'].mean():,.2f}")
print(f"  Mediana:   S/ {dias_sin_fraude['Monto_dia'].median():,.2f}")
print(f"  Máximo:    S/ {dias_sin_fraude['Monto_dia'].max():,.2f}")

print("\nTop 10 días con mayor monto acumulado y fraude:")
display(
