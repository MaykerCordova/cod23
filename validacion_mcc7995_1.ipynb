# %%
# ============================================================
# VALIDACIÓN 7 — INTERVALO ENTRE TRANSACCIONES (velocidad temporal)
# Valida la Hoja 6 del Excel
# ============================================================
print("=" * 60)
print("VALIDACIÓN 7 — INTERVALO ENTRE TRANSACCIONES")
print("=" * 60)

df_vel_val = df.sort_values([
    "ID_CLIENTE",
    "DATETIME"
]).copy()
df_vel_val[
    "PREV_DT"
] = df_vel_val.groupby("ID_CLIENTE")[
    "DATETIME"
].shift(1)
df_vel_val[
    "MIN_DESDE_PREV"
] = (
    df_vel_val[
    "DATETIME"
] - df_vel_val[
    "PREV_DT"
]
).dt.total_seconds() / 60

df_vel_val2 = df_vel_val.dropna(subset=[
    "MIN_DESDE_PREV"
])
df_vel_val2 = df_vel_val2[df_vel_val2[
        "MIN_DESDE_PREV"
    ] >= 0
].copy()

def bucket_intervalo(m):
    if   m <=  2: return "≤2 min"
    elif m <=  5: return "≤5 min"
    elif m <= 10: return "≤10 min"
    elif m <= 15: return "≤15 min"
    elif m <= 20: return "≤20 min"
    elif m <= 60: return "≤1 hora"
    else:         return ">1 hora"

ORDEN_BUCKETS = [
    "≤2 min",
    "≤5 min",
    "≤10 min",
    "≤15 min",
    "≤20 min",
    "≤1 hora",
    ">1 hora"
]
df_vel_val2[
    "BUCKET"
] = pd.Categorical(
    df_vel_val2[
    "MIN_DESDE_PREV"
].apply(bucket_intervalo),
    categories=ORDEN_BUCKETS, ordered=True
)

tabla_vel_val = (
    df_vel_val2.groupby("BUCKET", observed=True)
    .agg(
        Total            =("MONTO",
"count"),
        Fraude_Total     =("ES_FRAUDE",
"sum"),
        Fraude_Aprobado  =("ES_FRAUDE_APROBADO",
"sum"),
        FR_Total_pct     =("ES_FRAUDE",           lambda x: x.mean()*100),
        FR_Aprobado_pct  =("ES_FRAUDE_APROBADO",  lambda x: x.mean()*100),
    )
)
display(tabla_vel_val)
print("\n→ Compara Fraude_Total, Fraude_Aprobado y FR_Aprobado_pct")
print("  con la Hoja '6_Velocidad_Intervalo' del Excel")

# Drill-down por cliente específico en velocidad
print(f"\nVelocidad del cliente {ID_CLIENTE_TEST}:")
df_vel_cliente = df_vel_val2[df_vel_val2[
        "ID_CLIENTE"
    ] == ID_CLIENTE_TEST
]
if len(df_vel_cliente) > 0:
    display(df_vel_cliente[
    [
        "DATETIME",
        "PREV_DT",
        "MIN_DESDE_PREV",
        "BUCKET",
        "MONTO",
        "ES_FRAUDE_APROBADO"
    ]
].reset_index(drop=True))
else:
    print("  (Este cliente solo tiene 1 transacción — no hay intervalo calculable)")

