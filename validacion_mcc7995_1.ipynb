# %%
# ── CELDA 1: Imports y configuración ─────────────────────────────────────────
import pandas as pd
import numpy as np
from IPython.display import display

# Ajusta estas rutas
RUTA_PARQUET   = r"C:\ruta\al\consolidado_7995.parquet"
ID_CLIENTE_TEST = None  # ← pon aquí un ID cliente específico para validar velocidad
                        #   ej: "12345678"  Si dejas None toma el primero que tenga fraude

COLS = {
    "FECHA": "ACF-FECHA TRX",
    "HORA": "ACF-HORA TRX",
    "DATETIME": "FECHA_HORA",
    "COMERCIO": "ACF-NOMBRE/LOCALIZACION COMERCIO",
    "INDICADOR": "ACF-INDICADOR DE FRAUDE",
    "COD_RESPUESTA": "ACF-COD RPTA",
    "CONDICION_RT": "CONDICION RT",
    "CANAL": "ACF-CANAL",
    "ENTRY_MODE": "ACF-ENTRY MODE",
    "SALDO": "ACF-SALDO DISPONIBLE EN MONEDA TRX",
    "ID_CLIENTE": "ACF-ID CLIENTE",
    "ESI_UCAP": "ACF-ECI/UCAF",
    "PAIS": "ACF-PAIS ORIGEN 87519",
    "COD_RED_COMERCIO": "ACF-COD RED COMERCIO",
    "MONTO": "ACF-MONTO EN MONEDA LOCAL",
    "SEGMENTO": "VAA-EVENTO DE COMPROMISO OTRA FUENTE",
    "TIPO_PRODUCTO": "ACF-TIPO PROD TC",
}

print("✅ Configuración cargada")

# %%
# ── CELDA 2: Carga y preparación (igual que el script principal) ──────────────
df_raw = pd.read_parquet(RUTA_PARQUET)
col_map = {v: k for k, v in COLS.items()
}
df = df_raw.rename(columns=col_map).copy()

df[
    "MONTO"
]    = pd.to_numeric(df[
    "MONTO"
],    errors="coerce")
df[
    "SALDO"
]    = pd.to_numeric(df[
    "SALDO"
],    errors="coerce")
df[
    "DATETIME"
] = pd.to_datetime(df[
    "DATETIME"
], errors="coerce")
df[
    "FECHA"
]    = df[
    "DATETIME"
].dt.normalize()
df[
    "MES"
]      = df[
    "DATETIME"
].dt.to_period("M").astype(str)

for c in [
    "INDICADOR",
    "COD_RESPUESTA",
    "CONDICION_RT",
    "CANAL",
    "ESI_UCAP",
    "COD_RED_COMERCIO",
    "SEGMENTO",
    "TIPO_PRODUCTO"
]:
    if c in df.columns:
        df[c
] = df[c
].astype(str).str.strip().str.upper()

df[
    "ESTADO"
] = df[
    "COD_RESPUESTA"
].apply(
    lambda x: "APROBADA" if str(x).strip() in [
    "00",
    "0000",
    "000",
    "0"
] else "DENEGADA"
)
df[
    "ES_FRAUDE"
]          = (df[
    "INDICADOR"
] == "F").astype(int)
df[
    "ES_FRAUDE_APROBADO"
] = (
    (df[
    "INDICADOR"
] == "F") & (df[
    "ESTADO"
] == "APROBADA")
).astype(int)
df[
    "SEGURO"
]   = df[
    "ESI_UCAP"
].apply(
    lambda x: "Seguro" if str(x).strip() in [
    "2",
    "5"
] else "No Seguro"
)
df[
    "COND_088"
] = df[
    "CONDICION_RT"
].str.contains("088", na=False)

df_ap  = df[df[
        "ESTADO"
    ] == "APROBADA"
].copy()
df_den = df[df[
        "ESTADO"
    ] == "DENEGADA"
].copy()

print(f"Registros totales:  {len(df):,}")
print(f"Aprobadas:          {len(df_ap):,}")
print(f"Denegadas:          {len(df_den):,}")

# %%
# ============================================================
# VALIDACIÓN 1 — TOTALES GENERALES
# Compara contra Hoja 1 del Excel (Resumen Ejecutivo)
# ============================================================
print("=" * 60)
print("VALIDACIÓN 1 — TOTALES GENERALES")
print("=" * 60)

val1 = pd.DataFrame({
    "Métrica": [
        "Total registros",
        "Aprobadas",
        "Denegadas",
        "Fraude TOTAL (F en cualquier estado)",
        "Fraude APROBADO (F + APROBADA)",
        "Monto total aprobado (S/)",
        "Monto fraude total (S/)",
        "Monto fraude aprobado (S/)",
        "Ticket promedio aprobadas (S/)",
        "Ticket promedio fraude aprobado (S/)",
        "N° clientes únicos (aprobadas)",
    ],
    "Valor calculado": [
        f"{len(df):,}",
        f"{len(df_ap):,}",
        f"{len(df_den):,}",
        f"{df['ES_FRAUDE'].sum():,}",
        f"{df['ES_FRAUDE_APROBADO'].sum():,}",
        f"S/ {df_ap['MONTO'].sum():,.2f}",
        f"S/ {df[df['ES_FRAUDE']==1]['MONTO'].sum():,.2f}",
        f"S/ {df[df['ES_FRAUDE_APROBADO']==1]['MONTO'].sum():,.2f}",
        f"S/ {df_ap['MONTO'].mean():,.2f}",
        f"S/ {df[df['ES_FRAUDE_APROBADO']==1]['MONTO'].mean():,.2f}",
        f"{df_ap['ID_CLIENTE'].nunique():,}",
    ],
    "¿Coincide con Excel?": [
        "⬜ verificar"
    ] * 11
})

display(val1)
print("\n→ Compara cada valor con la Hoja '1_Resumen_Ejecutivo' del Excel")
print("  Si coincide: ✅  |  Si difiere: ❌ anota la diferencia")

# %%
# ============================================================
# VALIDACIÓN 2 — FLAGS: SEGURO / NO SEGURO
# Compara contra Hoja 7 (Por Dimension - Seguridad Comercio)
# ============================================================
print("=" * 60)
print("VALIDACIÓN 2 — FLAG SEGURO / NO SEGURO (ESI_UCAP)")
print("=" * 60)

print("\nValores únicos en ESI_UCAP (para entender qué hay):")
print(df[
    "ESI_UCAP"
].value_counts().head(20).to_string())

print("\n--- Clasificación aplicada ---")
print(f"  Seguro   (2 o 5): {(df['SEGURO']=='Seguro').sum():,}")
print(f"  No Seguro (resto): {(df['SEGURO']=='No Seguro').sum():,}")

print("\n--- Validación manual: ¿los valores 2 y 5 son todos los seguros? ---")
check_seguro = df.groupby("ESI_UCAP").agg(
    Total        =("MONTO",
"count"),
    Clasificado  =("SEGURO",             lambda x: x.iloc[
    0
]),
    Fraude_Total =("ES_FRAUDE",
"sum"),
    Fraude_Ap    =("ES_FRAUDE_APROBADO",
"sum"),
).sort_values("Total", ascending=False)
display(check_seguro)
print("\n→ Verifica que '2' y '5' aparezcan como 'Seguro' y el resto como 'No Seguro'")
print("  Si hay valores inesperados avísame para ajustar la lógica")

# %%
# ============================================================
# VALIDACIÓN 3 — FRAUDE TOTAL vs APROBADO por mes
# Compara contra Hoja 1 del Excel columna por columna
# ============================================================
print("=" * 60)
print("VALIDACIÓN 3 — FRAUDE TOTAL vs APROBADO POR MES")
print("=" * 60)

val3 = (
    df.groupby("MES")
    .agg(
        Aprobadas       =("ESTADO",             lambda x: (x=="APROBADA").sum()),
        Denegadas       =("ESTADO",             lambda x: (x=="DENEGADA").sum()),
        Fraude_Total    =("ES_FRAUDE",
"sum"),
        Fraude_Aprobado =("ES_FRAUDE_APROBADO",
"sum"),
        Monto_F_Total   =("MONTO",              lambda x: x[df.loc[x.index,
        "ES_FRAUDE"
    ]==1
].sum()),
        Monto_F_Ap      =("MONTO",              lambda x: x[df.loc[x.index,
        "ES_FRAUDE_APROBADO"
    ]==1
].sum()),
    )
    .assign(
        Diferencia_fraude = lambda x: x[
    "Fraude_Total"
] - x[
    "Fraude_Aprobado"
],
        Pct_fraude_en_den = lambda x: (x[
    "Fraude_Total"
] - x[
    "Fraude_Aprobado"
]) / x[
    "Fraude_Total"
] * 100,
    )
)
display(val3)
print("\n→ 'Diferencia_fraude' = fraudes que estaban en transacciones DENEGADAS")
print("  Compara Fraude_Aprobado y Monto_F_Ap con la Hoja 1 del Excel por mes")

# %%
# ============================================================
# VALIDACIÓN 4 — TRANSACCIONES POR DÍA POR CLIENTE (velocidad)
# Valida la tabla de la Hoja 5 del Excel
# ============================================================
print("=" * 60)
print("VALIDACIÓN 4 — VELOCIDAD DIARIA POR CLIENTE")
print("=" * 60)

# Replicar el cálculo exacto
dia_cliente_val = (
    df_ap
    .assign(FECHA_DIA=lambda x: x[
    "DATETIME"
].dt.date)
    .groupby([
    "ID_CLIENTE",
    "FECHA_DIA"
])
    .agg(
        Trx_dia              =("MONTO",
"count"),
        Monto_dia            =("MONTO",
"sum"),
        Fraudes_tot_dia      =("ES_FRAUDE",
"sum"),
        Fraudes_ap_dia       =("ES_FRAUDE_APROBADO",
"sum"),
        Monto_fraude_ap_dia  =("MONTO",               lambda x: x[df_ap.loc[x.index,
        "ES_FRAUDE_APROBADO"
    ]==1
].sum()),
    )
    .reset_index()
)

print(f"\nPares únicos cliente-día: {len(dia_cliente_val):,}")
print(f"Clientes únicos:          {dia_cliente_val['ID_CLIENTE'].nunique():,}")
print(f"Días únicos:              {dia_cliente_val['FECHA_DIA'].nunique():,}")

print("\nDistribución de trx/día por cliente:")
dist = dia_cliente_val[
    "Trx_dia"
].value_counts().sort_index()
display(dist.head(15).to_frame("Pares cliente-día"))

print("\nVerificación de totales:")
print(f"  Total trx aprobadas (suma):  {dia_cliente_val['Trx_dia'].sum():,}")
print(f"  Total trx aprobadas (real):  {len(df_ap):,}")
print(f"  ¿Coinciden? {'✅' if dia_cliente_val['Trx_dia'].sum() == len(df_ap) else '❌'}")

print(f"\n  Total fraude aprobado (suma): {dia_cliente_val['Fraudes_ap_dia'].sum():,}")
print(f"  Total fraude aprobado (real): {df['ES_FRAUDE_APROBADO'].sum():,}")
print(f"  ¿Coinciden? {'✅' if dia_cliente_val['Fraudes_ap_dia'].sum() == df['ES_FRAUDE_APROBADO'].sum() else '❌'}")

# %%
# ============================================================
# VALIDACIÓN 5 — CLIENTE ESPECÍFICO (drill-down)
# Valida las transacciones de un cliente concreto
# ============================================================
print("=" * 60)
print("VALIDACIÓN 5 — DRILL DOWN POR CLIENTE")
print("=" * 60)

# Si no se especificó, toma el primero con fraude aprobado
if ID_CLIENTE_TEST is None:
    clientes_con_fraude = df[df[
        "ES_FRAUDE_APROBADO"
    ]==1
][
    "ID_CLIENTE"
].unique()
    if len(clientes_con_fraude) > 0:
        ID_CLIENTE_TEST = clientes_con_fraude[
    0
]
        print(f"  (Auto-seleccionado cliente con fraude: {ID_CLIENTE_TEST})")
    else:
        print("  No hay clientes con fraude aprobado — usando primer cliente disponible")
        ID_CLIENTE_TEST = df_ap[
    "ID_CLIENTE"
].iloc[
    0
]

df_cliente = df_ap[df_ap[
        "ID_CLIENTE"
    ] == ID_CLIENTE_TEST
].sort_values("DATETIME").copy()
df_cliente[
    "FECHA_DIA"
] = df_cliente[
    "DATETIME"
].dt.date

print(f"\nCliente: {ID_CLIENTE_TEST}")
print(f"Total transacciones aprobadas: {len(df_cliente):,}")
print(f"Fraude total:    {df_cliente['ES_FRAUDE'].sum():,}")
print(f"Fraude aprobado: {df_cliente['ES_FRAUDE_APROBADO'].sum():,}")
print(f"Monto total:     S/ {df_cliente['MONTO'].sum():,.2f}")
print(f"Monto fraude ap: S/ {df_cliente[df_cliente['ES_FRAUDE_APROBADO']==1]['MONTO'].sum():,.2f}")

print("\nDetalle por día:")
resumen_dias = (
    df_cliente
    .groupby("FECHA_DIA")
    .agg(
        Trx             =("MONTO",
"count"),
        Monto_acumulado =("MONTO",
"sum"),
        Fraude_Total    =("ES_FRAUDE",
"sum"),
        Fraude_Aprobado =("ES_FRAUDE_APROBADO",
"sum"),
        Monto_F_Ap      =("MONTO",               lambda x: x[df_cliente.loc[x.index,
        "ES_FRAUDE_APROBADO"
    ]==1
].sum()),
    )
    .assign(Bucket_dia=lambda x: x[
    "Trx"
].apply(
        lambda n: str(n) if n<=6 else ("7-9" if n<=9 else ("10-12" if n<=12 else "13+"))
    ))
)
display(resumen_dias)

