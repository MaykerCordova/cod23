import polars as pl
from pathlib import Path

carpeta = Path(r"C:\Users\s4930359\Data_Herramientas\BBDD_VRM")

archivos = [
    "Consolidado.xlsx",
    "Consolidado_V2.xlsx",
    "Consolidado_V3.xlsx",
    "Consolidado_V4.xlsx",
]

# Leer solo los headers de cada archivo
for archivo in archivos:
    ruta = carpeta / archivo
    try:
        df = pl.read_excel(ruta, n_rows=3)
        print(f"\n{'='*60}")
        print(f"{archivo}: {df.shape[1]} columnas")
        print(f"Columnas: {df.columns}")
    except Exception as e:
        print(f"\n{archivo}: ERROR - {e}")

# Comparar columnas entre archivos
print(f"\n{'='*60}")
print("COMPARACIÓN DE COLUMNAS")
print(f"{'='*60}")

dfs = {}
for archivo in archivos:
    ruta = carpeta / archivo
    try:
        df = pl.read_excel(ruta, n_rows=1)
        dfs[archivo] = set(df.columns)
    except:
        pass

# Tomar el primero como referencia
ref_name = archivos[0]
ref_cols = dfs.get(ref_name, set())

for archivo, cols in dfs.items():
    if archivo == ref_name:
        continue
    nuevas = cols - ref_cols
    faltantes = ref_cols - cols
    print(f"\n{archivo} vs {ref_name}:")
    if nuevas:
        print(f"  Columnas NUEVAS (no están en {ref_name}): {nuevas}")
    if faltantes:
        print(f"  Columnas FALTANTES (están en {ref_name} pero no aquí): {faltantes}")
    if not nuevas and not faltantes:
        print(f"  ✓ Columnas idénticas")
