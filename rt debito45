columnas_texto = [
    "tarjeta_registro", "mcc", "pais_origen", "nombre_comercio", 
    "general_arco", "bim", "tbr", "indicador_fraude", "usuario"
]
columnas_float = ["monto_dolar", "monto_moneda_local"] # Agregué el de moneda local que mencionaste

# 2. Filtramos la v4 (desde el 1 de enero de 2025)
df_v4_filtrado = df_v4.filter(
    pl.col("fecha_transaccion") >= date(2025, 1, 1)
)

# 3. Detectamos las columnas en común automáticamente
columnas_comunes = list(set(df_v4_filtrado.columns) & set(df_v5.columns))

# 4. Función para estandarizar tipos de datos solo en las columnas compartidas
def preparar_para_union(df, comunes):
    # Validamos qué columnas de nuestras listas realmente existen en este cruce
    txt_aplicar = [col for col in columnas_texto if col in comunes]
    flt_aplicar = [col for col in columnas_float if col in comunes]
    
    # Seleccionamos las columnas comunes y forzamos el tipo de dato
    return df.select(comunes).with_columns(
        pl.col(txt_aplicar).cast(pl.String),
        pl.col(flt_aplicar).cast(pl.Float64)
        # Nota: fecha_transaccion no se toca, se queda como Date
    )

# 5. Aplicamos la limpieza y unimos (UNION ALL)
df_consolidado = pl.concat([
    preparar_para_union(df_v4_filtrado, columnas_comunes),
    preparar_para_union(df_v5, columnas_comunes)
])

print("Total de filas tras la unión:", df_consolidado.height)
print("Tipos de datos finales:\n", df_consolidado.schema)
