def construir_features(df: pl.DataFrame) -> pl.DataFrame:
    """Construye todas las familias de features sobre el DataFrame."""

    # Ordenar por cliente y tiempo — CRÍTICO para ventanas
    df = df.sort(["cliente_id", "datetime_trx"])

    # ── 2.1 Features temporales ───────────────────────────────────────────────
    df = df.with_columns([
        pl.col("datetime_trx").dt.hour().alias("hora"),
        pl.col("datetime_trx").dt.weekday().alias("dia_semana"),  # 0=Lun, 6=Dom
        pl.col("datetime_trx").dt.timestamp("ms").alias("ts_ms"),
    ])

    df = df.with_columns([
        # Horario nocturno
        ((pl.col("hora") >= 22) | (pl.col("hora") <= 6))
            .cast(pl.Int8).alias("flag_nocturno"),
        # Fin de semana
        (pl.col("dia_semana") >= 5)
            .cast(pl.Int8).alias("flag_fin_semana"),
        # Encoding cíclico
        (2 * np.pi * pl.col("hora") / 24).sin().alias("hora_sin"),
        (2 * np.pi * pl.col("hora") / 24).cos().alias("hora_cos"),
    ])

    # ── 2.2 Tiempo desde última transacción del cliente (segundos) ────────────
    df = df.with_columns(
        pl.col("ts_ms").diff().over("cliente_id").alias("ms_desde_ultima_trx")
    ).with_columns(
        (pl.col("ms_desde_ultima_trx") / 1000).alias("seg_desde_ultima_trx")
    )

    # ── 2.3 Ratio monto / saldo ───────────────────────────────────────────────
    df = df.with_columns([
        (pl.col("monto") / (pl.col("saldo_disponible") + 1))
            .alias("ratio_monto_saldo"),
    ])
    df = df.with_columns([
        (pl.col("ratio_monto_saldo") > 0.85).cast(pl.Int8).alias("flag_vaciado"),
    ])

    # ── 2.4 Banco destino de riesgo ───────────────────────────────────────────
    df = df.with_columns(
        (pl.col("banco_destino").str.to_uppercase().str.contains(BANCO_RIESGO))
            .cast(pl.Int8).alias("flag_dest_riesgo")
    )

    # ── 2.5 Primera vez que cliente transfiere a esta cuenta destino ──────────
    # Rank por (cliente_id, cuenta_destino) ordenado en el tiempo
    df = df.with_columns(
        pl.col("datetime_trx")
          .rank("ordinal")
          .over(["cliente_id", "cuenta_destino"])
          .alias("rank_cuenta_destino")
    )
    df = df.with_columns(
        (pl.col("rank_cuenta_destino") == 1).cast(pl.Int8).alias("es_primera_vez_destino")
    )

    # ── 2.6 Cuentas mula — cuántos clientes distintos recibió esa cuenta ─────
    receptores = (
        df.group_by("cuenta_destino")
          .agg([
              pl.col("cliente_id").n_unique().alias("n_clientes_a_cuenta_destino"),
              pl.col("monto").sum().alias("monto_total_recibido_cuenta"),
          ])
    )
    df = df.join(receptores, on="cuenta_destino", how="left")

    # ── 2.7 Ventanas de velocidad por cliente ─────────────────────────────────
    # Polars rolling sobre grupos — usamos sort + group_by_dynamic
    # Calculamos: n_trx y monto_acum en ventanas de 3min, 5min, 1h, 12h, 24h

    ventanas = {
        "3min":  3 * 60 * 1000,
        "5min":  5 * 60 * 1000,
        "1h":    1 * 3600 * 1000,
        "12h":  12 * 3600 * 1000,
        "24h":  24 * 3600 * 1000,
    }

    # Para ventanas rolling necesitamos ts como columna de índice
    # Estrategia: self-join con filtro de ventana (eficiente en Polars lazy)
    for nombre, ms in ventanas.items():
        ventana_roll = (
            df.lazy()
              .sort(["cliente_id", "ts_ms"])
              .with_columns([
                  pl.col("ts_ms")
                    .rolling_count(window_size=f"{ms}i", by="ts_ms")
                    .over("cliente_id")
                    .alias(f"n_trx_{nombre}"),
                  pl.col("monto")
                    .rolling_sum(window_size=f"{ms}i", by="ts_ms")
                    .over("cliente_id")
                    .alias(f"monto_acum_{nombre}"),
              ])
              .collect()
        )
        # Agregar columnas al df principal
        df = df.with_columns([
            ventana_roll[f"n_trx_{nombre}"],
            ventana_roll[f"monto_acum_{nombre}"],
        ])

    # ── 2.8 Ratio monto vs promedio del segmento ──────────────────────────────
    avg_segmento = (
        df.group_by("segmento")
          .agg(pl.col("monto").mean().alias("avg_monto_segmento"))
    )
    df = df.join(avg_segmento, on="segmento", how="left")
    df = df.with_columns(
        (pl.col("monto") / (pl.col("avg_monto_segmento") + 1))
            .alias("ratio_monto_vs_segmento")
    )

    # ── 2.9 Features compuestas ───────────────────────────────────────────────
    df = df.with_columns([
        # Ráfaga hacia banco de riesgo
        ((pl.col("n_trx_5min") >= 2) & (pl.col("flag_dest_riesgo") == 1))
            .cast(pl.Int8).alias("flag_rafaga_destino_riesgo"),
        # Vaciado hacia cuenta nueva
        ((pl.col("flag_vaciado") == 1) & (pl.col("es_primera_vez_destino") == 1))
            .cast(pl.Int8).alias("flag_vaciado_cuenta_nueva"),
        # Triple señal: ráfaga + nocturno + destino riesgo
        ((pl.col("n_trx_5min") >= 2) &
         (pl.col("flag_nocturno") == 1) &
         (pl.col("flag_dest_riesgo") == 1))
            .cast(pl.Int8).alias("flag_alto_riesgo"),
    ])

    return df


