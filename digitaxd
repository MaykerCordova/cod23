def cargar_y_preparar(ruta: str, cols: dict, encoding: str = "latin-1") -> pl.DataFrame:
    """Carga el CSV, renombra columnas y prepara tipos base."""
    df = (
        pl.read_csv(ruta, encoding=encoding, infer_schema_length=10000)
        .rename({v_orig: v_std for v_orig, v_std in cols.items()
                 if v_orig in pl.read_csv(ruta, encoding=encoding, n_rows=0).columns})
    )

    # Parsear datetime combinando fecha + hora si están separadas
    if "fecha_trx" in df.columns and "hora_trx" in df.columns:
        if df["fecha_trx"].dtype == pl.Utf8:
            df = df.with_columns(
                pl.concat_str(["fecha_trx", "hora_trx"], separator=" ")
                  .str.to_datetime(format="%Y-%m-%d %H:%M:%S", strict=False)
                  .alias("datetime_trx")
            )
        else:
            df = df.with_columns(
                pl.col("fecha_trx").cast(pl.Datetime).alias("datetime_trx")
            )
    elif "fecha_trx" in df.columns:
        df = df.with_columns(
            pl.col("fecha_trx").str.to_datetime(strict=False).alias("datetime_trx")
        )

    # Variable objetivo binaria: F=1, resto=0
    if "indicador_fraude" in df.columns:
        df = df.with_columns(
            (pl.col("indicador_fraude") == "F").cast(pl.Int8).alias("es_fraude")
        )

    # Tipos numéricos
    for col in ["monto", "saldo_disponible"]:
        if col in df.columns:
            df = df.with_columns(pl.col(col).cast(pl.Float64, strict=False))

    return df


