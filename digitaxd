def evaluar_regla(df: pl.DataFrame, nombre: str, expr_regla: pl.Expr):
    """
    Evalúa una regla de control mostrando:
    - Precision: % de alertas que son fraude real
    - Recall: % de fraudes reales capturados por la regla
    - Trx bloqueadas normales (falsos positivos)
    """
    df_eval = df.with_columns(expr_regla.cast(pl.Int8).alias("_alerta"))
    
    tp = df_eval.filter((pl.col("_alerta") == 1) & (pl.col("es_fraude") == 1)).shape[0]
    fp = df_eval.filter((pl.col("_alerta") == 1) & (pl.col("es_fraude") == 0)).shape[0]
    fn = df_eval.filter((pl.col("_alerta") == 0) & (pl.col("es_fraude") == 1)).shape[0]
    
    total_fraudes = df["es_fraude"].sum()
    total_alertas = tp + fp
    
    precision  = tp / (total_alertas + 1e-10)
    recall     = tp / (total_fraudes + 1e-10)
    f1         = 2 * precision * recall / (precision + recall + 1e-10)
    
    monto_fraude_capturado = (
        df_eval.filter((pl.col("_alerta") == 1) & (pl.col("es_fraude") == 1))
               ["monto"].sum()
    )
    monto_total_fraude = df_eval.filter(pl.col("es_fraude") == 1)["monto"].sum()
    
    print(f"\n  Regla: {nombre}")
    print(f"  {'─'*50}")
    print(f"  Alertas generadas : {total_alertas:,}  ({total_alertas/df.shape[0]*100:.1f}% del total)")
    print(f"  Fraudes capturados: {tp:,} / {total_fraudes:,}  (Recall = {recall*100:.1f}%)")
    print(f"  Falsos positivos  : {fp:,}")
    print(f"  Precision         : {precision*100:.1f}%")
    print(f"  F1-Score          : {f1:.3f}")
    print(f"  Monto fraude capt.: S/ {monto_fraude_capturado:,.0f} / S/ {monto_total_fraude:,.0f} ({monto_fraude_capturado/monto_total_fraude*100:.1f}%)")


