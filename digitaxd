def tasa_fraude_por_flag(df: pl.DataFrame, col_flag: str) -> pl.DataFrame:
    """Para features binarias: tasa de fraude cuando flag=1 vs flag=0."""
    return (
        df.group_by(col_flag)
          .agg([
              pl.len().alias("n_trx"),
              pl.col("es_fraude").sum().alias("n_fraudes"),
              pl.col("es_fraude").mean().alias("fraud_rate"),
              pl.col("monto").sum().alias("monto_total"),
          ])
          .sort(col_flag)
          .with_columns(
              (pl.col("monto_total") / pl.col("monto_total").sum() * 100)
                  .alias("pct_monto")
          )
    )


def tasa_fraude_por_decil(df: pl.DataFrame, col_num: str, n: int = 10) -> pl.DataFrame:
    """Para features numéricas: divide en deciles y calcula tasa de fraude."""
    return (
        df.with_columns(
            pl.col(col_num)
              .qcut(n, labels=[str(i) for i in range(1, n+1)])
              .alias(f"decil_{col_num}")
        )
        .group_by(f"decil_{col_num}")
        .agg([
            pl.len().alias("n_trx"),
            pl.col("es_fraude").sum().alias("n_fraudes"),
            pl.col("es_fraude").mean().alias("fraud_rate"),
            pl.col("monto").sum().alias("monto_fraudulento")
                .filter(pl.col("es_fraude") == 1),
        ])
        .sort(f"decil_{col_num}")
    )


