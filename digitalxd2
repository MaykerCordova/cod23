# df = df.with_columns(
#     pl.col("codigo_auth").is_in(["SM", "EM", ""]).cast(pl.Int8).alias("flag_auth_debil")
# )

# ── 2.10 Features compuestas ──────────────────────────────────────────────────
df = df.with_columns([
    ((pl.col("n_trx_5min") >= 2) & (pl.col("flag_dest_riesgo") == 1))
        .cast(pl.Int8).alias("flag_rafaga_dest_riesgo"),
    ((pl.col("flag_vaciado") == 1) & (pl.col("es_primera_vez_destino") == 1))
        .cast(pl.Int8).alias("flag_vaciado_cuenta_nueva"),
    ((pl.col("n_trx_5min") >= 2) & (pl.col("flag_nocturno") == 1) & (pl.col("flag_dest_riesgo") == 1))
        .cast(pl.Int8).alias("flag_alto_riesgo"),
])

print("  ✓ Features construidas")
print(f"  Columnas totales: {df.shape[1]}")


# ──────────────────────────────────────────────────────────────────────────────
# 3. TABLA RESUMEN POR INDICADOR DE FRAUDE
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("TABLA RESUMEN POR INDICADOR DE FRAUDE")
print("="*70)
print("""
  F = Fraude confirmado  |  N = Normal  |  G = Good (cliente confirmó)
  D = Descarte analista  |  P = Pendiente
""")

resumen_indicador = (
    df.group_by("indicador_fraude")
      .agg([
