      .sort("n_trx", descending=True)
)


# ──────────────────────────────────────────────────────────────────────────────
# 2. INGENIERÍA DE VARIABLES
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("CONSTRUYENDO FEATURES")
print("="*70)

# Ordenar por cliente y tiempo — CRÍTICO para ventanas rolling
df = df.sort(["cliente_id", "datetime_trx"])

# ── 2.1 Temporales ────────────────────────────────────────────────────────────
df = df.with_columns([
    pl.col("datetime_trx").dt.hour().alias("hora"),
    pl.col("datetime_trx").dt.weekday().alias("dia_semana"),
    pl.col("datetime_trx").dt.timestamp("ms").alias("ts_ms"),
])

df = df.with_columns([
    ((pl.col("hora") >= 22) | (pl.col("hora") <= 6)).cast(pl.Int8).alias("flag_nocturno"),
    (pl.col("dia_semana") >= 5).cast(pl.Int8).alias("flag_fin_semana"),
    (2 * np.pi * pl.col("hora") / 24).sin().alias("hora_sin"),
    (2 * np.pi * pl.col("hora") / 24).cos().alias("hora_cos"),
])

# ── 2.2 Tiempo desde última trx del cliente (segundos) ───────────────────────
df = df.with_columns(
    (pl.col("ts_ms").diff().over("cliente_id") / 1000).alias("seg_desde_ultima_trx")
)

# ── 2.3 Ratio monto / saldo ───────────────────────────────────────────────────
df = df.with_columns(
    (pl.col("monto") / (pl.col("saldo_disponible") + 1)).alias("ratio_monto_saldo")
)
df = df.with_columns(
    (pl.col("ratio_monto_saldo") > 0.85).cast(pl.Int8).alias("flag_vaciado")
)

# ── 2.4 Banco destino de riesgo ───────────────────────────────────────────────
df = df.with_columns(
    pl.col("banco_destino").str.to_uppercase()
      .str.contains(BANCO_RIESGO).cast(pl.Int8).alias("flag_dest_riesgo")
)

# ── 2.5 Primera vez que cliente transfiere a esta cuenta destino ──────────────
df = df.with_columns(
    pl.col("datetime_trx").rank("ordinal")
      .over(["cliente_id", "cuenta_destino"])
      .alias("_rank_cuenta")
)
df = df.with_columns(
    (pl.col("_rank_cuenta") == 1).cast(pl.Int8).alias("es_primera_vez_destino")
)

# ── 2.6 Cuentas mula — cuántos clientes distintos recibió esa cuenta ─────────
receptores = (
    df.group_by("cuenta_destino")
      .agg([
          pl.col("cliente_id").n_unique().alias("n_clientes_a_cuenta_destino"),
          pl.col("monto").sum().alias("monto_total_recibido_cuenta"),
      ])
)
df = df.join(receptores, on="cuenta_destino", how="left")

# ── 2.7 Ventanas de velocidad rolling ────────────────────────────────────────
ventanas = {
    "3min": 3  * 60 * 1000,
    "5min": 5  * 60 * 1000,
    "1h":   1  * 3600 * 1000,
    "12h":  12 * 3600 * 1000,
    "24h":  24 * 3600 * 1000,
}

for nombre, ms in ventanas.items():
    df = (
        df.lazy()
          .sort(["cliente_id", "ts_ms"])
          .with_columns([
              pl.col("ts_ms")
                .rolling_count(window_size=f"{ms}i", by="ts_ms")
                .over("cliente_id")
                .alias(f"n_trx_{nombre}"),
              pl.col("monto")
                .rolling_sum(window_size=f"{ms}i", by="ts_ms")
                .over("cliente_id")
                .alias(f"monto_acum_{nombre}"),
          ])
          .collect()
    )

# ── 2.8 Ratio monto vs promedio del segmento ──────────────────────────────────
avg_seg = df.group_by("segmento").agg(
    pl.col("monto").mean().alias("avg_monto_segmento")
)
df = df.join(avg_seg, on="segmento", how="left")
df = df.with_columns(
    (pl.col("monto") / (pl.col("avg_monto_segmento") + 1)).alias("ratio_monto_vs_segmento")
)

# ── 2.9 Método de autenticación (PENDIENTE — descomenta cuando tengas la col) ─
# df = df.with_columns(
#     pl.col("nombre_comercio").str.slice(-2).alias("codigo_auth")
# )
# MAPA_AUTH = {"PN": "Push Notification", "TI": "Touch ID",
#              "FI": "Face ID", "SM": "SMS", "EM": "Email"}
# df = df.with_columns(
#     pl.col("codigo_auth").replace(MAPA_AUTH, default="Desconocido").alias("tipo_auth")
# )
