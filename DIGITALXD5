# )

# ── 3.10 Features compuestas ──────────────────────────────────────────────────
df = df.with_columns([
    # Ráfaga hacia banco de riesgo
    ((pl.col("n_trx_5min") >= 2) & (pl.col("flag_dest_riesgo") == 1))
        .cast(pl.Int8).alias("flag_rafaga_dest_riesgo"),
    # Triple señal: ráfaga + nocturno + banco riesgo
    ((pl.col("n_trx_5min") >= 2) &
     (pl.col("flag_nocturno") == 1) &
     (pl.col("flag_dest_riesgo") == 1))
        .cast(pl.Int8).alias("flag_alto_riesgo"),
    # Vaciado + cuenta nueva — PENDIENTE saldo
    pl.lit(0).cast(pl.Int8).alias("flag_vaciado_cuenta_nueva"),
])

print(f"  ✓ Todas las features construidas — {df.shape[1]} columnas totales")


# ──────────────────────────────────────────────────────────────────────────────
# 4. DISCRIMINACIÓN DE FEATURES BINARIAS
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("4. DISCRIMINACIÓN DE FEATURES BINARIAS")
print("   Lift > 1  →  la condición concentra más fraude que el promedio")
print("   Lift = 3  →  3x más probable que sea fraude cuando flag = 1")
print("="*70)

flags = [
    "flag_nocturno",
    "flag_fin_semana",
    "flag_dest_riesgo",
    "es_primera_vez_destino",
    "flag_rafaga_dest_riesgo",
    "flag_alto_riesgo",
    # "flag_vaciado",              # pendiente — requiere saldo_disponible
    # "flag_vaciado_cuenta_nueva", # pendiente — requiere saldo_disponible
    # "flag_auth_debil",           # pendiente — requiere nombre_comercio
]

resumen_flags = []
for flag in flags:
    if flag not in df.columns:
        continue
    t = df.group_by(flag).agg([
        pl.len().alias("n_trx"),
        pl.col("es_fraude").sum().alias("n_fraudes"),
        pl.col("es_fraude").mean().alias("fraud_rate"),
        pl.col("monto").filter(pl.col("es_fraude") == 1).sum().alias("monto_fraude"),
    ])
    f1 = t.filter(pl.col(flag) == 1)
    f0 = t.filter(pl.col(flag) == 0)
    if f1.is_empty() or f0.is_empty():
        continue
    fr1 = f1["fraud_rate"][0]
    fr0 = f0["fraud_rate"][0]
    resumen_flags.append({
        "feature":             flag,
        "fraud_rate_flag1_%":  round(fr1 * 100, 3),
        "fraud_rate_flag0_%":  round(fr0 * 100, 3),
        "lift":                round(fr1 / (fr0 + 1e-10), 2),
        "n_trx_alertadas":     f1["n_trx"][0],
        "fraudes_capturados":  f1["n_fraudes"][0],
        "monto_fraude_cap_S/": round(f1["monto_fraude"][0] or 0, 0),
    })

print(pl.DataFrame(resumen_flags).sort("lift", descending=True))


# ──────────────────────────────────────────────────────────────────────────────
# 5. TABLA DE UMBRALES DE MONTO
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("5. TABLA DE UMBRALES DE MONTO")
print("   Lectura: si activo el control para trx con monto >= umbral,")
print("   ¿qué % de fraude capturo y qué % de trx normales afecto?")
print("="*70)

total_fraudes      = int(df["es_fraude"].sum())
total_normales     = df.shape[0] - total_fraudes
monto_fraude_total = df.filter(pl.col("es_fraude") == 1)["monto"].sum()

# Ajusta estos umbrales según el rango de montos de tu data
umbrales = [500, 1000, 1500, 2000, 3000, 5000, 7500, 10000, 15000, 20000]

filas = []
for u in umbrales:
    sub = df.filter(pl.col("monto") >= u)
    nf  = int(sub["es_fraude"].sum())
    nn  = sub.shape[0] - nf
    mc  = sub.filter(pl.col("es_fraude") == 1)["monto"].sum()
    filas.append({
        "umbral_S/":            u,
        "fraudes_capturados":   nf,
        "recall_fraude_%":      round(nf / (total_fraudes + 1e-10) * 100, 1),
        "monto_fraude_cap_S/":  round(mc, 0),
        "pct_monto_fraude_%":   round(mc / monto_fraude_total * 100, 1),
        "normales_afectados":   nn,
        "pct_normales_afect_%": round(nn / (total_normales + 1e-10) * 100, 1),
        "precision_%":          round(nf / (sub.shape[0] + 1e-10) * 100, 2),
    })

tabla_umbrales = pl.DataFrame(filas)
print(tabla_umbrales)
print(f"\n  Referencia — Total fraudes  : {total_fraudes:,}")
print(f"  Referencia — Total normales : {total_normales:,}")
print(f"  Referencia — Monto fraude   : S/ {monto_fraude_total:,.0f}")

# ── 5b. Umbral combinado: monto >= X  AND  banco destino riesgo ───────────────
print("\n── UMBRALES COMBINADOS: monto >= X  AND  banco destino riesgo ───────")
print("   Más quirúrgico — solo afecta trx hacia el banco de riesgo\n")

filas_comb = []
for u in umbrales:
    sub = df.filter((pl.col("monto") >= u) & (pl.col("flag_dest_riesgo") == 1))
    if sub.shape[0] == 0:
        continue
    nf = int(sub["es_fraude"].sum())
    nn = sub.shape[0] - nf
    mc = sub.filter(pl.col("es_fraude") == 1)["monto"].sum()
    filas_comb.append({
        "umbral_S/":            u,
        "fraudes_capturados":   nf,
        "recall_fraude_%":      round(nf / (total_fraudes + 1e-10) * 100, 1),
        "monto_fraude_cap_S/":  round(mc, 0),
        "normales_afectados":   nn,
        "precision_%":          round(nf / (sub.shape[0] + 1e-10) * 100, 2),
    })

print(pl.DataFrame(filas_comb))


# ──────────────────────────────────────────────────────────────────────────────
# 6. EVALUACIÓN DE REGLAS DE CONTROL
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("6. EVALUACIÓN DE REGLAS DE CONTROL")
print("="*70)

def evaluar_regla(df: pl.DataFrame, nombre: str, expr: pl.Expr):
    df_e      = df.with_columns(expr.cast(pl.Int8).alias("_alerta"))
    tp        = df_e.filter((pl.col("_alerta") == 1) & (pl.col("es_fraude") == 1)).shape[0]
    fp        = df_e.filter((pl.col("_alerta") == 1) & (pl.col("es_fraude") == 0)).shape[0]
    total_f   = int(df["es_fraude"].sum())
    total_a   = tp + fp
    precision = tp / (total_a  + 1e-10)
    recall    = tp / (total_f  + 1e-10)
    f1        = 2 * precision * recall / (precision + recall + 1e-10)
    monto_c   = df_e.filter((pl.col("_alerta") == 1) & (pl.col("es_fraude") == 1))["monto"].sum()
    monto_tf  = df.filter(pl.col("es_fraude") == 1)["monto"].sum()
    print(f"\n  {'─'*55}")
    print(f"  Regla    : {nombre}")
    print(f"  Alertas  : {total_a:,}  ({total_a/df.shape[0]*100:.1f}% del universo)")
    print(f"  Recall   : {recall*100:.1f}%  ({tp:,} de {total_f:,} fraudes capturados)")
    print(f"  Precision: {precision*100:.1f}%  |  F1: {f1:.3f}")
    print(f"  FP (normales afectados) : {fp:,}")
    print(f"  Monto fraude capturado  : S/ {monto_c:,.0f}  ({monto_c/monto_tf*100:.1f}% del total)")

evaluar_regla(df, "R1 — Banco destino riesgo",
    pl.col("flag_dest_riesgo") == 1)

evaluar_regla(df, "R2 — Ráfaga >= 2 trx en 5 min",
    pl.col("n_trx_5min") >= 2)

evaluar_regla(df, "R3 — Banco riesgo + primera vez a esa cuenta",
    (pl.col("flag_dest_riesgo") == 1) & (pl.col("es_primera_vez_destino") == 1))

evaluar_regla(df, "R4 — Rafaga 5min + banco riesgo",
    pl.col("flag_rafaga_dest_riesgo") == 1)

evaluar_regla(df, "R5 — Triple señal (rafaga + nocturno + banco riesgo)",
    pl.col("flag_alto_riesgo") == 1)

evaluar_regla(df, "R6 — OR combinado: R3 + R4",
    ((pl.col("flag_dest_riesgo") == 1) & (pl.col("es_primera_vez_destino") == 1)) |
    (pl.col("flag_rafaga_dest_riesgo") == 1))

