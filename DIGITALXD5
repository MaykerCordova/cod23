RUTA_8750 = r"C:\Users\s4930359\Data_Herramientas\data\transferencias\8750_marzo.csv"

# Cambia el VALOR (lado derecho) por el nombre exacto en tu archivo
COLUMNAS = {
    "cliente_id":     "cliente_id",        # ID único de cliente
    "monto":          "monto",             # Monto de la transferencia
    "fecha_trx":      "fecha_trx",         # Fecha
    "hora_trx":       "hora_trx",          # Hora HH:MM:SS
    "banco_destino":  "banco_destino",     # Banco destino
    "cuenta_destino": "cuenta_destino",    # Número de cuenta destino
    "segmento":       "segmento",          # Segmento del cliente
    "indicador":      "indicador_fraude",  # F / N / G / D / P
    # ── PENDIENTES — descomenta cuando tengas las columnas ──────────────────
    # "saldo":           "saldo_disponible",
    # "canal":           "canal",
    # "nombre_comercio": "nombre_comercio",
}

BANCO_RIESGO = "INTERBANK"

OUTPUT_DIR = Path(r"C:\Users\s4930359\Data_Herramientas\data\Gold\transferencias")


# ──────────────────────────────────────────────────────────────────────────────
# 1. CARGA Y PREPARACIÓN
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("1. CARGANDO Y PREPARANDO DATA")
print("="*70)

df = pl.read_csv(RUTA_8750, encoding="latin-1", infer_schema_length=10000)

# Renombrar solo las columnas que existen en el archivo
rename_map = {v: k for k, v in COLUMNAS.items() if v in df.columns}
df = df.rename(rename_map)

# Parsear datetime combinando fecha + hora
if "fecha_trx" in df.columns and "hora_trx" in df.columns:
    df = df.with_columns(
        pl.concat_str(["fecha_trx", "hora_trx"], separator=" ")
          .str.to_datetime(format="%Y-%m-%d %H:%M:%S", strict=False)
          .alias("datetime_trx")
    )
elif "fecha_trx" in df.columns:
    df = df.with_columns(
        pl.col("fecha_trx").str.to_datetime(strict=False).alias("datetime_trx")
    )

# Monto a float
df = df.with_columns(pl.col("monto").cast(pl.Float64, strict=False))

# Variable objetivo: F=1, resto=0
df = df.with_columns(
    (pl.col("indicador_fraude") == "F").cast(pl.Int8).alias("es_fraude")
)

print(f"  Filas totales      : {df.shape[0]:,}")
print(f"  Fraudes (F)        : {df['es_fraude'].sum():,}")
print(f"  Fraud rate global  : {df['es_fraude'].mean()*100:.3f}%")
print(f"  Monto total fraude : S/ {df.filter(pl.col('es_fraude')==1)['monto'].sum():,.0f}")


# ──────────────────────────────────────────────────────────────────────────────
# 2. DISTRIBUCIÓN POR INDICADOR DE FRAUDE
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("2. DISTRIBUCIÓN POR INDICADOR DE FRAUDE")
print("   F=Fraude | N=Normal | G=Good | D=Descarte | P=Pendiente")
print("="*70)

print(
    df.group_by("indicador_fraude")
      .agg([
          pl.len().alias("n_trx"),
          pl.col("cliente_id").n_unique().alias("n_clientes"),
          pl.col("monto").sum().alias("monto_total"),
          pl.col("monto").mean().round(2).alias("monto_promedio"),
          pl.col("monto").median().round(2).alias("monto_mediana"),
          pl.col("monto").max().alias("monto_maximo"),
      ])
      .with_columns([
          (pl.col("n_trx") / pl.col("n_trx").sum() * 100).round(2).alias("pct_trx"),
          (pl.col("monto_total") / pl.col("monto_total").sum() * 100).round(2).alias("pct_monto"),
      ])
      .sort("monto_total", descending=True)
)


# ──────────────────────────────────────────────────────────────────────────────
# 3. INGENIERÍA DE VARIABLES
# ──────────────────────────────────────────────────────────────────────────────

print("\n" + "="*70)
print("3. CONSTRUYENDO FEATURES")
print("="*70)

# Ordenar por cliente y tiempo — CRÍTICO para rolling
df = df.sort(["cliente_id", "datetime_trx"])

# ── 3.1 Temporales ────────────────────────────────────────────────────────────
df = df.with_columns([
    pl.col("datetime_trx").dt.hour().alias("hora"),
    pl.col("datetime_trx").dt.weekday().alias("dia_semana"),
])

df = df.with_columns([
    ((pl.col("hora") >= 22) | (pl.col("hora") <= 6))
        .cast(pl.Int8).alias("flag_nocturno"),
    (pl.col("dia_semana") >= 5)
        .cast(pl.Int8).alias("flag_fin_semana"),
    (2 * np.pi * pl.col("hora") / 24).sin().alias("hora_sin"),
    (2 * np.pi * pl.col("hora") / 24).cos().alias("hora_cos"),
])

# ── 3.2 Tiempo desde última trx del cliente (segundos) ───────────────────────
df = df.with_columns(
    pl.col("datetime_trx")
      .diff()
      .over("cliente_id")
      .dt.total_seconds()
      .alias("seg_desde_ultima_trx")
)

# ── 3.3 Saldo disponible — PENDIENTE ─────────────────────────────────────────
# Cuando tengas saldo_disponible, descomenta y elimina los pl.lit():
# df = df.with_columns(
#     (pl.col("monto") / (pl.col("saldo_disponible") + 1)).alias("ratio_monto_saldo")
# )
# df = df.with_columns(
#     (pl.col("ratio_monto_saldo") > 0.85).cast(pl.Int8).alias("flag_vaciado")
# )
df = df.with_columns([
    pl.lit(None).cast(pl.Float64).alias("ratio_monto_saldo"),
    pl.lit(0).cast(pl.Int8).alias("flag_vaciado"),
])

# ── 3.4 Banco destino de riesgo ───────────────────────────────────────────────
df = df.with_columns(
    pl.col("banco_destino")
      .str.to_uppercase()
      .str.contains(BANCO_RIESGO)
      .cast(pl.Int8)
      .alias("flag_dest_riesgo")
)

# ── 3.5 Primera vez que cliente transfiere a esta cuenta destino ──────────────
df = df.with_columns(
    pl.col("datetime_trx")
      .rank("ordinal")
      .over(["cliente_id", "cuenta_destino"])
      .alias("_rank_cuenta")
)
df = df.with_columns(
    (pl.col("_rank_cuenta") == 1).cast(pl.Int8).alias("es_primera_vez_destino")
).drop("_rank_cuenta")

# ── 3.6 Cuentas mula — cuántos clientes distintos recibió esa cuenta ─────────
receptores = (
    df.group_by("cuenta_destino")
      .agg([
          pl.col("cliente_id").n_unique().alias("n_clientes_a_cuenta_destino"),
          pl.col("monto").sum().alias("monto_total_recibido_cuenta"),
      ])
)
df = df.join(receptores, on="cuenta_destino", how="left")

# ── 3.7 Ventanas de velocidad rolling (sintaxis Polars 1.x) ──────────────────
# rolling_sum_by usa directamente la columna datetime como índice temporal
ventanas = {
    "3min": "3m",
    "5min": "5m",
    "1h":   "1h",
    "12h":  "12h",
    "24h":  "24h",
}

for nombre, ventana in ventanas.items():
    df = (
        df.lazy()
          .sort(["cliente_id", "datetime_trx"])
          .with_columns([
              # Monto acumulado en la ventana
              pl.col("monto")
                .rolling_sum_by("datetime_trx", window_size=ventana)
                .over("cliente_id")
                .alias(f"monto_acum_{nombre}"),
              # Conteo: suma de unos en la ventana
              pl.lit(1).cast(pl.Float64)
                .rolling_sum_by("datetime_trx", window_size=ventana)
                .over("cliente_id")
                .cast(pl.Int32)
                .alias(f"n_trx_{nombre}"),
          ])
          .collect()
    )

print("  ✓ Ventanas rolling construidas")

# ── 3.8 Ratio monto vs promedio del segmento ──────────────────────────────────
avg_seg = df.group_by("segmento").agg(
    pl.col("monto").mean().alias("avg_monto_segmento")
)
df = df.join(avg_seg, on="segmento", how="left")
df = df.with_columns(
    (pl.col("monto") / (pl.col("avg_monto_segmento") + 1))
        .alias("ratio_monto_vs_segmento")
)

# ── 3.9 Método de autenticación — PENDIENTE ───────────────────────────────────
# Cuando tengas nombre_comercio, descomenta:
# df = df.with_columns(
#     pl.col("nombre_comercio").str.slice(-2).alias("codigo_auth")
# )
# MAPA_AUTH = {"PN": "Push Notification", "TI": "Touch ID",
#              "FI": "Face ID",           "SM": "SMS", "EM": "Email"}
# df = df.with_columns(
#     pl.col("codigo_auth").replace(MAPA_AUTH, default="Desconocido").alias("tipo_auth")
# )
# df = df.with_columns(
