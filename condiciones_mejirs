# ⚠️  NO se necesitan credenciales. Win32com usa el Outlook abierto en tu PC.
OUTLOOK_FOLDER   = "condiciones automatizadas"      # nombre exacto de la carpeta/regla en Outlook

BASE_DIR         = Path(__file__).resolve().parent  # carpeta donde vive este script
INGESTA_DIR      = BASE_DIR / "_ingesta"            # Excel descargado cae aquí
HISTORICO_PATH   = BASE_DIR / "_historico_comercios.xlsx"

ICORR_SEMILLA_DEFAULT = 100000   # correlativo inicial para condiciones nuevas
REGISTROS_POR_TXT     = 800      # máximo de registros por archivo TXT
TOTAL_LEN_REGISTRO    = 875      # ancho fijo del registro posicional

# Columnas requeridas en el Excel fuente
COL_TARJETA    = "ACF-TARJETA REGISTRO 750"
COL_BANCO      = "ACF-CODIGO BANCO DESTINO TRANSF. INMEDIATA"
COL_FECHA      = "ACF-FECHA TRX"
COL_HORA       = "ACF-HORA TRX"
COL_CLIENTE    = "ACF-ID CLIENTE"
COL_COMERCIO   = "ACF-NOMBRE/LOCALIZACION COMERCIO"
COL_CONDICION  = "ACF-CONDICIONES QUE GENERARON ALERTA"

SKIP_ROWS = 4   # filas de metadatos antes del header en el Excel fuente

