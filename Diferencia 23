def _tema_corporativo():
    """Tema base compartido para todos los gráficos."""
    return (
        theme_minimal(base_family="Segoe UI", base_size=11) +
        theme(
            plot_title    = element_text(size=14, weight="bold", color="#333333"),
            axis_text_x   = element_text(rotation=45, hjust=1, size=9),
            axis_text_y   = element_text(size=9),
            axis_title    = element_blank(),
            legend_title  = element_blank(),
            legend_position = "bottom",
            panel_grid_major_x = element_blank(),
            panel_grid_major_y = element_line(color="#e0e0e0", size=0.5),
            panel_grid_minor   = element_blank(),
            plot_background    = element_rect(fill="white", color=None),
            panel_background   = element_rect(fill="white", color=None),
            figure_size   = (12, 6),
        )
    )


def plot_evolucion_mensual(df_full: pd.DataFrame,
                           outfile: str = PNG_MENSUAL) -> str:
    """
    Gráfico de evolución mensual de Txns UBA vs SBP (barras) y
    Txns Faltantes absolutas (línea + puntos).

    Usa plotnine (grammar of graphics).
    """
    # --- Preparar datos ---
    df = df_full.copy()
    df["Fecha"] = pd.to_datetime(df["Fecha"], errors="coerce")
    df = df.dropna(subset=["Fecha"])
    df["Mes_Anio"] = df["Fecha"].dt.to_period("M").dt.to_timestamp()

    df_mes = (
        df.sort_values("Fecha")
          .groupby("Mes_Anio", as_index=False)
          .agg({"Txns Faltantes": "sum", "Txns UBA": "sum", "Txns SBP": "sum"})
    )
    df_mes["Faltantes Abs"] = df_mes["Txns Faltantes"].abs()
    df_mes["Relacion"]      = np.where(
        df_mes["Txns Faltantes"] >= 0, "UBA ≥ SBP", "SBP > UBA"
    )

    # Formato largo para barras
    df_barras = pd.melt(
        df_mes,
        id_vars    = ["Mes_Anio"],
        value_vars = ["Txns UBA", "Txns SBP"],
        var_name   = "Fuente",
        value_name = "Txns"
    )

    paleta_barras = {"Txns UBA": COLOR_UBA, "Txns SBP": COLOR_SBP}
    paleta_pts    = {"UBA ≥ SBP": COLOR_OK, "SBP > UBA": COLOR_ALERTA}

    p = (
        ggplot() +

        # Barras UBA y SBP
        geom_col(
            data     = df_barras,
            mapping  = aes(x="Mes_Anio", y="Txns", fill="Fuente"),
            position = position_dodge(width=15),
            alpha    = 0.55,
            width    = 20,
        ) +
        scale_fill_manual(values=paleta_barras) +

        # Línea de magnitud faltantes
        geom_line(
            data    = df_mes,
            mapping = aes(x="Mes_Anio", y="Faltantes Abs"),
            color   = COLOR_UBA,
            size    = 1.1,
        ) +

        # Puntos coloreados por relación
        geom_point(
            data    = df_mes,
            mapping = aes(x="Mes_Anio", y="Faltantes Abs", color="Relacion"),
            size    = 3,
        ) +
        scale_color_manual(values=paleta_pts) +

        # Etiquetas sobre puntos
        geom_text(
            data    = df_mes,
            mapping = aes(x="Mes_Anio", y="Faltantes Abs",
                          label="Faltantes Abs"),
            format_string = "{:.0f}",
            nudge_y = df_mes["Faltantes Abs"].max() * 0.04,
            size    = 8,
            color   = "#333333",
        ) +

        scale_x_datetime(date_labels="%b-%Y", date_breaks="1 month") +
        scale_y_continuous(labels=lambda lst: [f"{x:,.0f}" for x in lst]) +

        labs(title="Evolución mensual de Transacciones Faltantes") +
        _tema_corporativo()
    )

    p.save(outfile, dpi=200, verbose=False)
    return os.path.abspath(outfile)


def plot_evolucion_diaria_ultimos_30_dias(df_full: pd.DataFrame,
                                          outfile: str = PNG_DIARIO30) -> str:
    """
    Gráfico de evolución diaria (últimos 30 días) de Txns Faltantes absolutas.
    Incluye:
      - Línea principal + puntos coloreados por relación UBA/SBP.
      - Línea horizontal de umbral fijo (0.5%).
      - Marcadores de outliers IQR (violeta) sobre los puntos anómalos.
      - Etiquetas de valor real en cada punto.
    """
    # --- Filtrar últimos 30 días ---
    df = df_full.copy()
    df["Fecha"] = pd.to_datetime(df["Fecha"], errors="coerce")
    if pd.api.types.is_datetime64tz_dtype(df["Fecha"]):
        df["Fecha"] = df["Fecha"].dt.tz_convert(None)
    df = df.dropna(subset=["Fecha"])

    hoy    = pd.Timestamp.today().normalize()
    inicio = hoy - pd.Timedelta(days=29)
    df     = df[(df["Fecha"] >= inicio) & (df["Fecha"] <= hoy)].sort_values("Fecha")

    if df.empty:
        return _grafico_vacio(outfile, "Sin datos en los últimos 30 días")

    # --- Calcular columnas auxiliares ---
    faltantes        = pd.to_numeric(df["Txns Faltantes"], errors="coerce")
    df["Falt Abs"]   = faltantes.abs()
    df["Relacion"]   = np.where(faltantes >= 0, "UBA ≥ SBP", "SBP > UBA")

    # Outliers IQR sobre el histórico completo
    outliers_mask    = detectar_outliers_iqr(df_full)
    df_full_c        = df_full.copy()
    df_full_c["Fecha"] = pd.to_datetime(df_full_c["Fecha"], errors="coerce")
    df_outliers      = df_full_c[outliers_mask].copy()
    df_outliers["Fecha"] = pd.to_datetime(df_outliers["Fecha"], errors="coerce")
    df_outliers      = df_outliers[
        (df_outliers["Fecha"] >= inicio) & (df_outliers["Fecha"] <= hoy)
    ].copy()
    df_outliers["Falt Abs"] = pd.to_numeric(
        df_outliers["Txns Faltantes"], errors="coerce"
    ).abs()

    # Umbral en unidades absolutas (aproximado: mediana de UBA * UMBRAL)
    umbral_abs = pd.to_numeric(df["Txns UBA"], errors="coerce").median() * UMBRAL

    paleta_pts = {"UBA ≥ SBP": COLOR_OK, "SBP > UBA": COLOR_ALERTA}

    p = (
        ggplot(df, aes(x="Fecha", y="Falt Abs")) +

        # Línea de umbral
        geom_hline(yintercept=umbral_abs,
                   color=COLOR_ALERTA, linetype="dashed", size=0.8, alpha=0.7) +

        # Línea principal
        geom_line(color=COLOR_UBA, size=1.1) +

        # Puntos coloreados por relación
        geom_point(aes(color="Relacion"), size=3) +
        scale_color_manual(values=paleta_pts) +

        # Outliers IQR marcados con anillo violeta (si los hay)
        (
            geom_point(
                data    = df_outliers,
                mapping = aes(x="Fecha", y="Falt Abs"),
                color   = COLOR_OUTLIER,
                size    = 6,
                shape   = "o",
                fill    = "none",
                stroke  = 1.8,
            ) if not df_outliers.empty else geom_point(alpha=0)
        ) +

        # Etiquetas de valor
        geom_text(
            aes(label="Falt Abs"),
            format_string = "{:.0f}",
            nudge_y = df["Falt Abs"].max() * 0.05 if df["Falt Abs"].max() > 0 else 1,
            size    = 8,
            color   = "#333333",
        ) +

        scale_x_datetime(date_labels="%d-%b", date_breaks="2 days") +
        scale_y_continuous(labels=lambda lst: [f"{x:,.0f}" for x in lst]) +
        labs(title="Evolución diaria (últimos 30 días) de Transacciones Faltantes",
             caption=f"— — Umbral fijo {UMBRAL*100:.1f}%  |  ○ Outlier estadístico (IQR)") +
        _tema_corporativo() +
        theme(figure_size=(14, 6))
    )

    p.save(outfile, dpi=200, verbose=False)
    return os.path.abspath(outfile)



def _grafico_vacio(outfile: str, mensaje: str) -> str:
    """Genera un PNG en blanco con mensaje cuando no hay datos."""
    import matplotlib.pyplot as plt
    fig, ax = plt.subplots(figsize=(10, 4))
    ax.text(0.5, 0.5, mensaje, ha="center", va="center", fontsize=14)
    ax.axis("off")
    plt.savefig(outfile, dpi=150, bbox_inches="tight", facecolor="white")
    plt.close()
    return os.path.abspath(outfile)


# ==========================
# Resumen estadístico para correo
# ==========================
def _resumen_outlier_iqr(df_full: pd.DataFrame) -> str:
    """
    Genera texto HTML de alerta estadística si el último día es outlier IQR.
    Incluye el límite calculado para transparencia.
    """
    serie = pd.to_numeric(df_full["% Diferencia"], errors="coerce").abs() * 100
    q1    = serie.quantile(0.25)
    q3    = serie.quantile(0.75)
    iqr   = q3 - q1
    limite = q3 + 1.5 * iqr
    ultimo = serie.iloc[-1] if not serie.empty else 0.0

    if pd.notna(ultimo) and ultimo > limite:
        return (
            f'<p style="color:{COLOR_OUTLIER};font-weight:bold;">'
            f'⚠ Alerta estadística (IQR): La diferencia de hoy ({ultimo:.2f}%) '
            f'supera el límite estadístico ({limite:.2f}% = Q3 + 1.5×IQR). '
            f'Revisar causa raíz.'
            f'</p>'
        )
    return ""


# ==========================
# Envío de correo
# ==========================
def _add_inline_image(mail, img_path: str, cid: str) -> str:
    """Adjunta una imagen y asigna Content-ID para incrustarla en HTML."""
    attach = mail.Attachments.Add(Source=img_path)
    attach.PropertyAccessor.SetProperty(
        "http://schemas.microsoft.com/mapi/proptag/0x3712001E", cid
    )
    attach.PropertyAccessor.SetProperty(
        "http://schemas.microsoft.com/mapi/proptag/0x3713001E", cid
    )
    return cid


# ==========================
# Flujo principal
# ==========================
def main():
    # ── 1. Leer estructura del Excel para columnas ──────────────────────────
    df_excel = pd.read_excel(RUTA_EXCEL)
    df2      = pd.DataFrame(columns=df_excel.columns)

    # ── 2. Extraer datos de correos ─────────────────────────────────────────
    extract_tables_from_emails(df2)

    # ── 3. Insertar fila(s) en Excel sin abrir instancia COM ────────────────
    #       Esto evita el problema de cierre de archivos abiertos.
    workbook = load_workbook(filename=RUTA_EXCEL)
    sheet    = workbook.active
    table    = sheet.tables["Tabla1"]

    inicio_ref, fin_ref = table.ref.split(":")
    start_col = "".join(filter(str.isalpha, inicio_ref))
    start_row = int("".join(filter(str.isdigit, inicio_ref)))
    end_col   = "".join(filter(str.isalpha, fin_ref))
    end_row   = int("".join(filter(str.isdigit, fin_ref)))

    fila_referencia = end_row

    for i, row in enumerate(df2.itertuples(index=False, name=None), start=1):
        sheet.append(row)
        for j, valor in enumerate(row, start=1):
            celda_nueva      = sheet.cell(row=fila_referencia + i, column=j)
            celda_referencia = sheet.cell(row=fila_referencia,     column=j)
            if celda_referencia.has_style:
                celda_nueva.font          = copy(celda_referencia.font)
                celda_nueva.border        = copy(celda_referencia.border)
                celda_nueva.fill          = copy(celda_referencia.fill)
                celda_nueva.number_format = copy(celda_referencia.number_format)
                celda_nueva.protection    = copy(celda_referencia.protection)
                celda_nueva.alignment     = copy(celda_referencia.alignment)

    nuevas_filas      = len(df2)
    nueva_ultima_fila = end_row + nuevas_filas
    table.ref         = f"{start_col}{start_row}:{end_col}{nueva_ultima_fila}"

    # ── NOTA: Ya NO se usa Excel COM (win32 Excel.Application).
    #    Guardamos directamente con openpyxl. Las fórmulas se recalculan
    #    la próxima vez que el usuario abra el archivo en Excel.
    workbook.save(filename=RUTA_EXCEL)

    # ── 4. Cargar histórico completo para gráficos ──────────────────────────
    df_full = pd.read_excel(RUTA_EXCEL)

    # ── 5. Generar gráficos ─────────────────────────────────────────────────
    img_path1 = plot_evolucion_mensual(df_full,                   PNG_MENSUAL)
    img_path2 = plot_evolucion_diaria_ultimos_30_dias(df_full,    PNG_DIARIO30)

    for path in [img_path1, img_path2]:
        if not os.path.exists(path):
            raise FileNotFoundError(f"No se generó el gráfico: {path}")

    # ── 6. Preparar datos para el correo ────────────────────────────────────
    fecha_val   = df2.iloc[0]["Fecha"]
    fecha_asunto = (
        pd.to_datetime(fecha_val, dayfirst=True)
        if isinstance(fecha_val, str)
        else pd.to_datetime(fecha_val)
    )

    txns_uba  = int(df2.iloc[0]["Txns UBA"])
    txns_sbp  = int(df2.iloc[0]["Txns SBP"])
    txns_falt = int(df2.iloc[0]["Txns Faltantes"])
    porc_diff = float(df2.iloc[0]["% Diferencia"])

    alerta_iqr_html = _resumen_outlier_iqr(df_full)

    # ── 7. Construir y enviar correo ─────────────────────────────────────────
    outlook = win32.Dispatch("outlook.application")
    mail    = outlook.CreateItem(0)

    mail.To = (
        "roberto.palacios@scotiabank.com.pe; "
        "Katherine.huapaya@scotiabank.com.pe; "
        "rodolfo.cordova@scotiabank.com.pe; "
    )
    mail.CC        = ""
    mail.Subject   = f"Informe Transacciones de Monitor al {fecha_asunto:%d/%m/%Y}"
    mail.BodyFormat = 2     # olFormatHTML
    mail.Importance = 1     # 1 = normal

    cid1 = _add_inline_image(mail, img_path1, "evolucion_txs")
    cid2 = _add_inline_image(mail, img_path2, "evolucion_txs_diaria")

    umbral_superado = (
        f"⚠ Superando el umbral del {UMBRAL*100}%."
        if abs(porc_diff) > UMBRAL
        else f"✔ No se superó el umbral del {UMBRAL*100}%."
    )

    mail.HTMLBody = f"""
    <html>
    <body style="font-family:Segoe UI,Arial,sans-serif;font-size:12.5px;color:#222;">
      <p>Estimados,</p>
      <p>
        En base a las transacciones recibidas por UNIBANCA <b>{txns_sbp:,}</b>
        y las enviadas desde UNIBANCA <b>{txns_uba:,}</b>.<br/>
        Se tiene una diferencia de <b>{abs(txns_falt):,}</b> transacciones faltantes.<br/>
        Porcentaje de diferencia para esta fecha es <b>{abs(porc_diff)*100:.3f}%</b>.<br/>
        <b>{umbral_superado}</b>
      </p>
      {alerta_iqr_html}
      <h4>Evolutivo Mensual de transacciones Faltantes</h4>
      <img src="cid:{cid1}" style="max-width:100%;height:auto;"/>
      <h4>Evolutivo diario de transacciones (últimos 30 días)</h4>
      <img src="cid:{cid2}" style="max-width:100%;height:auto;"/>
      <p>Saludos,<br/>Mayker Córdova</p>
    </body>
    </html>
    """

    mail.Send()
    print(f"[OK] Reporte enviado para la fecha {fecha_asunto:%d/%m/%Y}.")


