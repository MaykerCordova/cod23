# ==========================
# Conexión a Outlook
# ==========================
def _conectar_outlook_folder(folder_name: str):
    """Retorna la carpeta de Outlook con el nombre indicado."""
    outlook_ns   = win32.Dispatch("Outlook.Application").GetNamespace("MAPI")
    root_folder  = outlook_ns.GetDefaultFolder(6)   # 6 = Inbox
    for folder in root_folder.Folders:
        if folder.Name == folder_name:
            return folder
    raise ValueError(f"No se encontró la carpeta '{folder_name}' en Outlook.")


# ==========================
# Lógica de fines de semana
# ==========================
def _calcular_correos_a_leer() -> int:
    """
    Calcula cuántos correos deben leerse según el día de ejecución.

    Lógica:
      - Lunes (weekday=0): lee 4 correos (viernes→sábado, sábado→domingo,
        domingo→lunes... pero el proceso no corre sábado ni domingo,
        así que el lunes trae sábado y domingo = 2 correos extra → total 4).
        Nota: si hay feriado antes, se ajusta sumando días no ejecutados.
      - Martes a viernes (weekday=1-4): lee 2 correos (día anterior normal).
    """
    hoy = datetime.today().weekday()  # 0=lunes, 6=domingo
    if hoy == 0:    # Lunes
        return 4
    else:
        return 2


# ==========================
# Extracción de datos de correos
# ==========================
def extract_tables_from_emails(df2: pd.DataFrame) -> None:
    """
    Extrae los conteos de transacciones desde los últimos N correos del folder.

    Lógica:
      - N correos según día de semana (_calcular_correos_a_leer).
      - Subject "RV: [External] Transacciones enviadas" → Txns UBA.
      - Cualquier otro subject → Txns SBP.
      - Fecha = ReceivedTime - 1 día (los correos reportan el día anterior).
      - Calcula % Diferencia y Txns Faltantes.
      - Si hay múltiples correos (lunes), inserta múltiples filas en df2.

    Parameters
    ----------
    df2 : pd.DataFrame
        DataFrame de salida con las columnas del Excel destino.
        Se modificará in-place.
    """
    specific_folder = _conectar_outlook_folder(FOLDER_NAME)
    max_count       = _calcular_correos_a_leer()

    items = specific_folder.Items
    items.Sort("[ReceivedTime]", True)   # descendente → más recientes primero

    # Agrupar pares de correos por fecha
    buffer: dict[date, dict] = {}   # {fecha: {"UBA": int, "SBP": int}}

    count = 0
    for item in items:
        if count >= max_count:
            break
        try:
            if item.Class != 43:    # 43 = MailItem
                continue

            # Extraer número del body (últimas 6 palabras limpias)
            numero = int(
                " ".join(
                    item.Body.replace("\n", " ").replace(",", "").split()[-6:]
                )
            )

            fecha = (item.ReceivedTime - timedelta(days=1)).date()

            if fecha not in buffer:
                buffer[fecha] = {"UBA": None, "SBP": None}

            if item.Subject.startswith("RV: [External] Transacciones enviadas"):
                buffer[fecha]["UBA"] = numero
            else:
                buffer[fecha]["SBP"] = numero

            count += 1

        except (AttributeError, ValueError):
            continue

    # Construir filas del DataFrame
    filas = []
    for fecha, datos in sorted(buffer.items()):
        uba  = datos.get("UBA")
        sbp  = datos.get("SBP")
        if uba is not None and sbp is not None:
            diff_pct      = (uba - sbp) / uba if uba != 0 else 0.0
            txns_falt     = uba - sbp
            filas.append({
                "Fecha"         : fecha,
                "Txns UBA"      : uba,
                "Txns SBP"      : sbp,
                "% Diferencia"  : diff_pct,
                "Txns Faltantes": txns_falt,
            })

    # Llenar df2 con las filas encontradas
    if filas:
        df_new = pd.DataFrame(filas, columns=df2.columns)
        for col in df_new.columns:
            if col in df2.columns:
                df2[col] = df_new[col].values[0] if len(df_new) == 1 else None
        # Para lunes con múltiples fechas, expandir df2
        if len(filas) > 1:
            df2.drop(df2.index, inplace=True)
            for fila in filas:
                df2.loc[len(df2)] = fila


# ==========================
# Análisis estadístico IQR
# ==========================
def detectar_outliers_iqr(df_full: pd.DataFrame) -> pd.Series:
    """
    Marca como outlier estadístico cualquier día donde |% Diferencia|
    supera Q3 + 1.5 * IQR.

    Parameters
    ----------
    df_full : pd.DataFrame
        Histórico completo.

    Returns
    -------
    pd.Series (bool)
        True donde el punto es outlier estadístico.
    """
    serie = pd.to_numeric(df_full["% Diferencia"], errors="coerce").abs() * 100
    q1  = serie.quantile(0.25)
    q3  = serie.quantile(0.75)
    iqr = q3 - q1
    limite_superior = q3 + 1.5 * iqr
    return serie > limite_superior


