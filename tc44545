WITH estado_actual AS (
    SELECT *,
           ROW_NUMBER() OVER (
               PARTITION BY transaction_id
               ORDER BY fecha_descarga DESC
           ) AS rn
    FROM reclamos_master
)
SELECT
    strftime('%Y', purchase_date) AS year,
    strftime('%m', purchase_date) AS month,
    COUNT(*) AS reclamos,
    ROUND(SUM(fraud_amount), 2) AS monto
FROM estado_actual
WHERE rn = 1
GROUP BY year, month
ORDER BY year, month;

