def _ajustar_formula(formula: str, fila_origen: int, fila_destino: int) -> str:
    """
    Ajusta los números de fila en una fórmula Excel al copiarla a otra fila.
    Ejemplo: =B5-C5 copiada de fila 5 a fila 10 → =B10-C10
    """
    import re
    def reemplazar(match):
        letra = match.group(1)
        num   = int(match.group(2))
        if num == fila_origen:
            return f"{letra}{fila_destino}"
        return match.group(0)
    return re.sub(r"([A-Z]+)(\d+)", reemplazar, formula)


def main():
    # ── 1. Leer estructura del Excel para columnas ──────────────────────────
    df_excel = pd.read_excel(RUTA_EXCEL)
    df2      = pd.DataFrame(columns=df_excel.columns)

    # ── 2. Extraer datos de correos ─────────────────────────────────────────
    extract_tables_from_emails(df2)

    # ── 3. Insertar fila(s) en Excel sin abrir instancia COM ────────────────
    #       Esto evita el problema de cierre de archivos abiertos.
    workbook = load_workbook(filename=RUTA_EXCEL)
    sheet    = workbook.active
    table    = sheet.tables["Tabla1"]

    inicio_ref, fin_ref = table.ref.split(":")
    start_col = "".join(filter(str.isalpha, inicio_ref))
    start_row = int("".join(filter(str.isdigit, inicio_ref)))
    end_col   = "".join(filter(str.isalpha, fin_ref))
    end_row   = int("".join(filter(str.isdigit, fin_ref)))

    fila_referencia = end_row

    # Columnas que son formulas Excel (no se escribe valor, se replica la formula)
    COLS_FORMULA = {"% Diferencia", "Txns Faltantes"}
    col_names    = list(df_excel.columns)

    for i, row in enumerate(df2.itertuples(index=False, name=None), start=1):
        nueva_fila_num = fila_referencia + i
        ref_fila_num   = fila_referencia

        for j, valor in enumerate(row, start=1):
            celda_nueva      = sheet.cell(row=nueva_fila_num, column=j)
            celda_referencia = sheet.cell(row=ref_fila_num,   column=j)
            col_name         = col_names[j - 1] if j - 1 < len(col_names) else ""

            if col_name in COLS_FORMULA:
                # Replicar formula ajustando numero de fila
                if celda_referencia.data_type == "f" and celda_referencia.value:
                    formula_ref  = str(celda_referencia.value)
                    formula_new  = _ajustar_formula(formula_ref, ref_fila_num, nueva_fila_num)
                    celda_nueva.value = formula_new
                # Si no hay formula en la referencia, dejar vacia (Excel la calculara)
            else:
                # Columnas de valor directo: escribir el dato
                celda_nueva.value = valor

            # Copiar estilo en todos los casos
            if celda_referencia.has_style:
                celda_nueva.font          = copy(celda_referencia.font)
                celda_nueva.border        = copy(celda_referencia.border)
                celda_nueva.fill          = copy(celda_referencia.fill)
                celda_nueva.number_format = copy(celda_referencia.number_format)
                celda_nueva.protection    = copy(celda_referencia.protection)
                celda_nueva.alignment     = copy(celda_referencia.alignment)

    nuevas_filas      = len(df2)
    nueva_ultima_fila = end_row + nuevas_filas
    table.ref         = f"{start_col}{start_row}:{end_col}{nueva_ultima_fila}"

    # ── NOTA: Ya NO se usa Excel COM (win32 Excel.Application).
    #    Guardamos directamente con openpyxl. Las fórmulas se recalculan
    #    la próxima vez que el usuario abra el archivo en Excel.
    workbook.save(filename=RUTA_EXCEL)

    # ── 4. Cargar histórico completo para gráficos ──────────────────────────
    df_full = pd.read_excel(RUTA_EXCEL)

    # ── 5. Generar gráficos ─────────────────────────────────────────────────
    img_path1 = plot_evolucion_mensual(df_full,                   PNG_MENSUAL)
    img_path2 = plot_evolucion_diaria_ultimos_30_dias(df_full,    PNG_DIARIO30)

    for path in [img_path1, img_path2]:
        if not os.path.exists(path):
            raise FileNotFoundError(f"No se generó el gráfico: {path}")

    # ── 6. Preparar datos para el correo ────────────────────────────────────
    # Si hay múltiples fechas pendientes (lunes, feriados), el asunto
    # muestra el rango de fechas y el cuerpo lista cada día por separado.
    df2_sorted = df2.sort_values("Fecha")
    fechas_procesadas = pd.to_datetime(df2_sorted["Fecha"]).dt.strftime("%d/%m/%Y").tolist()

    if len(df2_sorted) == 1:
        # Caso normal: un solo día pendiente
        fila        = df2_sorted.iloc[0]
        asunto_str  = f"Informe Transacciones de Monitor al {fechas_procesadas[0]}"
        resumen_html = _bloque_resumen_fila(fila, df_full)
    else:
        # Caso múltiple: varios días pendientes (lunes, post-feriado, etc.)
        rango       = f"{fechas_procesadas[0]} al {fechas_procesadas[-1]}"
        asunto_str  = f"Informe Transacciones de Monitor del {rango}"
        resumen_html = "".join(
            _bloque_resumen_fila(df2_sorted.iloc[i], df_full)
            for i in range(len(df2_sorted))
        )

    alerta_iqr_html = _resumen_outlier_iqr(df_full)

    # ── 7. Construir y enviar correo ─────────────────────────────────────────
    outlook = win32.Dispatch("outlook.application")
    mail    = outlook.CreateItem(0)

    mail.To = (
        "roberto.palacios@scotiabank.com.pe; "
        "Katherine.huapaya@scotiabank.com.pe; "
        "rodolfo.cordova@scotiabank.com.pe; "
    )
    mail.CC         = ""
    mail.Subject    = asunto_str
    mail.BodyFormat = 2     # olFormatHTML
    mail.Importance = 1     # 1 = normal

    cid1 = _add_inline_image(mail, img_path1, "evolucion_txs")
    cid2 = _add_inline_image(mail, img_path2, "evolucion_txs_diaria")

    mail.HTMLBody = f"""
    <html>
    <body style="font-family:Segoe UI,Arial,sans-serif;font-size:12.5px;color:#222;">
      <p>Estimados,</p>
      {resumen_html}
      {alerta_iqr_html}
      <h4>Evolutivo Mensual de transacciones Faltantes</h4>
      <img src="cid:{cid1}" style="max-width:100%;height:auto;"/>
      <h4>Evolutivo diario de transacciones (últimos 30 días)</h4>
      <img src="cid:{cid2}" style="max-width:100%;height:auto;"/>
      <p>Saludos,<br/>Mayker Córdova</p>
    </body>
    </html>
    """

    mail.Send()
    print(f"[OK] Reporte enviado → {asunto_str}")


if __name__ == "__main__":
    main()
