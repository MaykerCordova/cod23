    "---\n",
    "## 7. Velocity — Detección de Ráfagas por BIN\n",
    "\n",
    "**Lógica:** Si el mismo BIN hace ≥ 3 transacciones en < 60 segundos, es sospechoso.  \n",
    "Esto detecta **BIN testing** — cuando un fraude prueba varias tarjetas rápidamente.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "10af897c",
   "metadata": {},
   "outputs": [],
   "source": [
    "VENTANA_SEG = 60   # segundos\n",
    "MIN_TXN     = 3    # mínimo transacciones en la ventana\n",
    "\n",
    "df_vel = df.sort_values([\"bin\",\"fecha_transaccion\"]).copy()\n",
    "df_vel[\"ts\"] = pd.to_datetime(df_vel[\"fecha_transaccion\"]).astype(np.int64)//1e9\n",
    "\n",
    "def velocity_flag(g):\n",
    "    ts = g[\"ts\"].values\n",
    "    flags = []\n",
    "    for t in ts:\n",
    "        burst = ((ts >= t - VENTANA_SEG) & (ts <= t + VENTANA_SEG)).sum()\n",
    "        flags.append(1 if burst >= MIN_TXN else 0)\n",
    "    return pd.Series(flags, index=g.index)\n",
    "\n",
    "df_vel[\"velocity_flag\"] = df_vel.groupby(\"bin\", group_keys=False).apply(velocity_flag)\n",
    "\n",
    "vel_rate = df_vel[\"velocity_flag\"].mean()\n",
    "print(f\"Transacciones en ráfaga: {df_vel['velocity_flag'].sum():,} ({vel_rate:.2%} del total)\")\n",
    "\n",
    "# Top BINs con más ráfagas\n",
    "top_vel = (df_vel[df_vel[\"velocity_flag\"]==1]\n",
    "           .groupby(\"bin\")[\"velocity_flag\"].sum()\n",
    "           .sort_values(ascending=False).head(10))\n",
    "print(\"\\nTop 10 BINs por eventos de velocity:\")\n",
    "print(top_vel.to_string())\n"
   ]
