   "source": [
    "# ── CARGA ──────────────────────────────────────────────────────────────────\n",
    "# OPCIÓN A: desde carpeta data/ (tu flujo normal)\n",
    "# OPCIÓN B: datos sintéticos (demo)\n",
    "\n",
    "USAR_SINTETICOS = True   # ← cambia a False y ajusta ARCHIVO para datos reales\n",
    "ARCHIVO         = r\"data\\tu_export_monitor.xlsx\"\n",
    "SKIPROWS        = 4       # filas de cabecera del Monitor antes de los datos\n",
    "\n",
    "def clean_names(df):\n",
    "    \"\"\"Limpia nombres de columnas: minúsculas, sin espacios ni caracteres especiales.\"\"\"\n",
    "    if HAS_JANITOR:\n",
    "        return df.clean_names()\n",
    "    df.columns = (df.columns\n",
    "                  .str.strip().str.lower()\n",
    "                  .str.replace(r\"[^\\w\\s]\", \"\", regex=True)\n",
    "                  .str.replace(r\"\\s+\", \"_\", regex=True)\n",
    "                  .str.replace(r\"_+\",  \"_\", regex=True)\n",
    "                  .str.strip(\"_\"))\n",
    "    return df\n",
    "\n",
    "if USAR_SINTETICOS:\n",
    "    # ── Generador sintético realista ─────────────────────────────────\n",
    "    np.random.seed(42)\n",
    "    rng = np.random.default_rng(42)\n",
    "    n   = 6000\n",
    "\n",
    "    comercios = [\"AMAZON\",\"MERCADO_LIBRE\",\"RAPPI\",\"UBER\",\"NETFLIX\",\n",
    "                 \"FALABELLA\",\"SAGA\",\"WONG\",\"PLAZAVEA\",\"COMERCIO_X\",\n",
    "                 \"GOOGLE_PLAY\",\"ALIEXPRESS\"]\n",
    "    mccs    = [\"5411\",\"5812\",\"7372\",\"4816\",\"5999\",\"6011\",\"7011\",\"5945\"]\n",
    "    canales = [\"E-COMMERCE\",\"POS\",\"ATM\",\"CONTACTLESS\"]\n",
    "    entries = [\"01\",\"02\",\"05\",\"07\",\"10\",\"81\",\"91\"]\n",
    "    cods    = [\"00\",\"N7\",\"04\",\"14\",\"51\",\"59\",\"53\",\"69\",\"05\",\"12\"]\n",
    "    c_probs = [0.50,0.10,0.04,0.04,0.08,0.06,0.04,0.04,0.05,0.05]\n",
    "\n",
    "    bins_normales      = [f\"4{rng.integers(10000,99999)}\" for _ in range(20)]\n",
    "    bins_comprometidos = [\"422052\",\"423011\",\"430150\"]\n",
    "    all_bins           = bins_normales + bins_comprometidos\n",
    "\n",
    "    base   = datetime(2024,10,1)\n",
    "    fechas = [base + timedelta(seconds=int(x)) for x in rng.integers(0,86400*90,n)]\n",
    "\n",
    "    comercio_arr = rng.choice(comercios, n)\n",
    "    bin_arr = []\n",
    "    for c in comercio_arr:\n",
    "        if c in [\"COMERCIO_X\",\"RAPPI\",\"ALIEXPRESS\"]:\n",
    "            w = np.array([0.05]*20 + [0.30,0.25,0.20]); w /= w.sum()\n",
    "        else:\n",
    "            w = np.array([1/23]*23)\n",
    "        bin_arr.append(rng.choice(all_bins, p=w))\n",
    "\n",
    "    montos = np.where(np.isin(bin_arr, bins_comprometidos),\n",
    "                      rng.lognormal(4.6,1.3,n),\n",
    "                      rng.lognormal(4.0,0.8,n)).round(2)\n",
    "\n",
    "    p_fraude = np.where(np.isin(bin_arr,[\"422052\"]),0.38,\n",
    "               np.where(np.isin(bin_arr,[\"423011\"]),0.28,\n",
    "               np.where(np.isin(bin_arr,[\"430150\"]),0.20,\n",
    "               np.where(np.isin(comercio_arr,[\"COMERCIO_X\"]),0.22,\n",
    "               np.where(np.isin(comercio_arr,[\"RAPPI\",\"ALIEXPRESS\"]),0.16,0.04)))))\n",
    "    p_fraude = np.clip(p_fraude + (montos>500)*0.08, 0, 0.92)\n",
    "\n",
    "    rand = rng.uniform(0,1,n)\n",
    "    ind  = np.where(rand<p_fraude,\"F\",\n",
    "           np.where(rand<p_fraude+0.12,\"G\",\n",
    "           np.where(rand<p_fraude+0.17,\"D\",\n",
    "           np.where(rand<p_fraude+0.20,\"P\",\"N\"))))\n",
    "\n",
    "    df_raw = pd.DataFrame({\n",
    "        \"fecha_transaccion\": fechas, \"monto\": montos,\n",
    "        \"comercio\": comercio_arr,    \"mcc\": rng.choice(mccs,n),\n",
    "        \"bin\": bin_arr,              \"tarjeta\": [f\"{rng.integers(1000,9999)}\" for _ in range(n)],\n",
    "        \"canal\": rng.choice(canales,n,p=[0.42,0.33,0.15,0.10]),\n",
    "        \"entry_mode\": rng.choice(entries,n),\n",
    "        \"indicador_fraude\": ind,\n",
    "        \"codigo_respuesta\": rng.choice(cods,n,p=c_probs),\n",
    "        \"id_cliente\": [f\"CLI{rng.integers(10000,99999)}\" for _ in range(n)],\n",
    "    })\n",
    "    print(f\"✅ Dataset sintético: {len(df_raw):,} filas | {df_raw.shape[1]} columnas\")\n",
    "\n",
    "else:\n",
    "    df_raw = pd.read_excel(ARCHIVO, skiprows=SKIPROWS, engine=\"openpyxl\")\n",
    "    df_raw = clean_names(df_raw)\n",
    "    print(f\"✅ Archivo cargado: {len(df_raw):,} filas | {df_raw.shape[1]} columnas\")\n",
    "\n",
    "df = df_raw.copy()\n"
   ]
  },
