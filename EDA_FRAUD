   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n",
    "top = ranking.head(10).reset_index()\n",
    "\n",
    "# Fraud rate horizontal\n",
    "colors_fr = [COLORS[\"fraude\"] if r>0.15 else\n",
    "             COLORS[\"warning\"] if r>0.07 else COLORS[\"muted\"]\n",
    "             for r in top[\"fraud_rate\"]]\n",
    "axes[0].barh(top[\"comercio\"][::-1], top[\"fraud_rate\"][::-1], color=colors_fr[::-1])\n",
    "axes[0].axvline(0.15, color=COLORS[\"warning\"], linestyle=\"--\", lw=1.5, label=\"Umbral 15%\")\n",
    "axes[0].set_title(\"Fraud Rate por Comercio\\n(solo etiquetas F y G)\", fontweight=\"bold\")\n",
    "axes[0].set_xlabel(\"Fraud Rate\"); axes[0].xaxis.set_major_formatter(mticker.PercentFormatter(1))\n",
    "axes[0].legend()\n",
    "\n",
    "# EFL scatter\n",
    "scatter = axes[1].scatter(top[\"fraud_rate\"], top[\"efl\"],\n",
    "                           s=top[\"txn_clean\"]/3, alpha=0.8,\n",
    "                           c=top[\"score\"], cmap=\"RdYlGn_r\")\n",
    "for _, row in top.iterrows():\n",
    "    axes[1].annotate(row[\"comercio\"], (row[\"fraud_rate\"], row[\"efl\"]),\n",
    "                     textcoords=\"offset points\", xytext=(5,3), fontsize=8)\n",
    "plt.colorbar(scatter, ax=axes[1], label=\"Score riesgo\")\n",
    "axes[1].set_title(\"Fraud Rate vs EFL\\n(tamaño = volumen txn)\", fontweight=\"bold\")\n",
