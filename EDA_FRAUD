   "source": [
    "# ── Ranking de comercios ──────────────────────────────────────────────────\n",
    "# Usamos SOLO F y G para el fraud_rate (etiquetas limpias)\n",
    "df_clean = df[df[\"indicador_fraude\"].isin([\"F\",\"G\"])].copy()\n",
    "df_clean[\"fraude_bin\"] = (df_clean[\"indicador_fraude\"]==\"F\").astype(int)\n",
    "\n",
    "ranking = (df_clean.groupby(\"comercio\")\n",
    "    .agg(txn_clean   =(\"fraude_bin\",\"count\"),\n",
    "         fraudes      =(\"fraude_bin\",\"sum\"),\n",
    "         monto_medio  =(\"monto\",\"mean\"),\n",
    "         monto_total  =(\"monto\",\"sum\"))\n",
    "    .assign(fraud_rate = lambda x: x[\"fraudes\"]/x[\"txn_clean\"],\n",
    "            severidad  = lambda x: np.where(x[\"fraudes\"]>0,\n",
    "                                            x[\"monto_total\"]/x[\"fraudes\"],0),\n",
    "            efl        = lambda x: x[\"fraud_rate\"]*x[\"monto_medio\"])\n",
    "    .sort_values(\"fraud_rate\", ascending=False))\n",
    "\n",
    "# Score compuesto\n",
    "ranking[\"score\"] = (\n",
    "    0.40*(ranking[\"fraud_rate\"]/ranking[\"fraud_rate\"].max()) +\n",
    "    0.35*(ranking[\"efl\"]/ranking[\"efl\"].max()) +\n",
    "    0.25*(ranking[\"severidad\"]/ranking[\"severidad\"].max())\n",
    ").round(4)\n",
    "\n",
    "ranking = ranking.sort_values(\"score\", ascending=False)\n",
    "print(ranking[[\"txn_clean\",\"fraudes\",\"fraud_rate\",\"efl\",\"severidad\",\"score\"]].head(12).to_string())\n"
   ]
